---
import SEO from '../components/SEO.astro';
import Analytics from '../components/Analytics.astro';
import BootScreen from '../components/BootScreen.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  showBoot?: boolean;
}

const { title, description = "Creative Developer & Dozent. Building next-gen web experiences.", showBoot = false } = Astro.props;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "David Schuchert",
  "jobTitle": "Full-Stack Developer, Dozent & Web Architect",
  "description": "Expert in Agentic AI, TypeScript, React and Laravel. Building immersive web experiences and teaching modern software engineering.",
  "url": "https://david-schuchert.de",
  "image": "https://avatars.githubusercontent.com/u/142668300?v=4",
  "sameAs": [
    "https://github.com/DavidSchuchert",
    "https://www.linkedin.com/in/david-schuchert-0ab892283/",
    "https://www.youtube.com/c/hochdruck3d"
  ],
  "knowsAbout": [
    "Software Architecture",
    "Agentic AI",
    "Full-Stack Development",
    "TypeScript",
    "React",
    "Laravel",
    "Three.js",
    "Retro Gaming Ethics"
  ],
  "hasOccupation": {
    "@type": "Occupation",
    "name": "Dozent für Fachinformatiker Anwendungsentwicklung",
    "description": "Lehrtätigkeit an der DBE-Academy in Bad Hersfeld."
  }
};
---

<!DOCTYPE html>
<html lang="de" class="dark scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#000000" />
  <meta name="robots" content="index, follow" />
  <meta name="author" content="David Schuchert" />

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <SEO title={title} description={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500&family=Inter:wght@300;400;500;600&family=Outfit:wght@300;500;700;800;900&family=Press+Start+2P&family=VT323&display=swap" rel="stylesheet" />
</head>
<body class="font-sans antialiased text-white bg-black selection:bg-accent-500 selection:text-white overflow-x-hidden">

  {showBoot && <BootScreen />}

  <slot />
  <Analytics />

  <!-- Mouse tracking for background effects -->
  <script is:inline>
    window.addEventListener('mousemove', (e) => {
      document.body.style.setProperty('--mouse-x', `${e.clientX}px`);
      document.body.style.setProperty('--mouse-y', `${e.clientY}px`);
    });
  </script>

</body>
</html>