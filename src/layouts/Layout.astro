---
import SEO from '../components/SEO.astro';
import Analytics from '../components/Analytics.astro';
import BootScreen from '../components/BootScreen.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Creative Developer & Dozent. Building next-gen web experiences." } = Astro.props;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "David Schuchert",
  "jobTitle": "Creative Developer & Dozent",
  "url": "https://david-schuchert.de",
  "sameAs": [
    "https://github.com/DavidSchuchert",
    "https://www.linkedin.com/in/david-schuchert-0ab892283/",
    "https://xing.com/profile/David_Schuchert",
    "https://www.youtube.com/c/hochdruck3d"
  ]
};
---

<!DOCTYPE html>
<html lang="de" class="dark scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#000000" />
  <meta name="robots" content="index, follow" />
  <meta name="author" content="David Schuchert" />

  <SEO title={title} description={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500&family=Inter:wght@300;400;500;600&family=Outfit:wght@300;500;700;800;900&family=Press+Start+2P&family=VT323&display=swap" rel="stylesheet" />
</head>
<body class="font-sans antialiased text-white bg-black selection:bg-accent-500 selection:text-white overflow-x-hidden cursor-none">

  <BootScreen />

  <!-- DYNAMIC GAME CURSOR -->
  <div id="game-cursor" class="fixed w-10 h-10 pointer-events-none z-[10000] flex items-center justify-center mix-blend-difference opacity-0 md:opacity-100 transition-opacity duration-300">
    <div class="cursor-dot w-2 h-2 bg-white rounded-full transition-all duration-300"></div>
    <div class="cursor-ring absolute inset-0 border border-white/40 rounded-full scale-100 transition-all duration-500"></div>
    <div class="cursor-hud absolute inset-0 border-t border-l border-cyan-400 rotate-45 opacity-0 scale-50 transition-all duration-700"></div>
    <span class="cursor-label absolute text-[7px] top-12 font-black tracking-widest uppercase opacity-40 whitespace-nowrap">INIT</span>
  </div>

  <slot />
  <Analytics />

  <!-- Mouse tracking & Era Detection -->
  <script is:inline>
    const cursor = document.getElementById('game-cursor');
    const cursorDot = cursor.querySelector('.cursor-dot');
    const cursorRing = cursor.querySelector('.cursor-ring');
    const cursorHud = cursor.querySelector('.cursor-hud');
    const cursorLabel = cursor.querySelector('.cursor-label');

    // 1. Snappier Cursor Follow
    let mouseX = 0;
    let mouseY = 0;
    let cursorX = 0;
    let cursorY = 0;
    let isActive = false;

    // Detect touch device
    const isTouch = ('ontouchstart' in window) || (navigator.maxTouchPoints > 0);
    if (isTouch) {
      cursor.style.display = 'none';
      document.body.classList.remove('cursor-none');
    }

    window.addEventListener('mousemove', (e) => {
      if (!isActive) {
        isActive = true;
        cursor.style.opacity = '1';
      }
      mouseX = e.clientX;
      mouseY = e.clientY;
      
      document.body.style.setProperty('--mouse-x', `${e.clientX}px`);
      document.body.style.setProperty('--mouse-y', `${e.clientY}px`);
    });

    function animateCursor() {
      // Improved interpolation (0.3 instead of 0.15 for better responsiveness)
      cursorX += (mouseX - cursorX) * 0.3;
      cursorY += (mouseY - cursorY) * 0.3;
      
      cursor.style.transform = `translate3d(${cursorX - 20}px, ${cursorY - 20}px, 0)`;
      requestAnimationFrame(animateCursor);
    }
    if (!isTouch) animateCursor();

    // 2. Era Detection & Cursor Styling
    const eraMapping = {
      'era-8bit': { cls: 'cursor-nes', label: '[8BIT_SCAN]' },
      'era-16bit': { cls: 'cursor-snes', label: '[16BIT_LINK]' },
      'era-gameboy': { cls: 'cursor-gb', label: '[MATRIX_DOT]' },
      'era-32bit': { cls: 'cursor-ps1', label: '[BIOS_HUD]' },
      'era-hd': { cls: 'cursor-hd', label: '[X_SYSTEM]' },
      'era-nextgen': { cls: 'cursor-ps5', label: '[DUALSENSE]' }
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const eraId = entry.target.id;
          const config = eraMapping[eraId];
          
          if (config) {
            cursorLabel.innerText = config.label;
            
            // Remove previous era classes
            Object.values(eraMapping).forEach(m => cursor.classList.remove(m.cls));
            // Add current era class
            cursor.classList.add(config.cls);
            
            // Trigger internal visual updates
            if (eraId === 'era-32bit') {
              cursorHud.style.opacity = '0.8';
              cursorHud.style.transform = 'rotate(45deg) scale(1.4)';
            } else {
              cursorHud.style.opacity = '0';
              cursorHud.style.transform = 'scale(0.5)';
            }
          }
        }
      });
    }, { threshold: 0.1 }); // More sensitive threshold

    // Watch all era divs
    document.querySelectorAll('[id^="era-"]').forEach(era => observer.observe(era));
  </script>

  <style is:global>
    @media (hover: hover) {
      * {
        cursor: none !important;
      }
    }

    /* ERA SPECIFIC CURSOR STYLES */
    #game-cursor.cursor-nes .cursor-ring,
    #game-cursor.cursor-nes .cursor-dot,
    #game-cursor.cursor-gb .cursor-ring,
    #game-cursor.cursor-gb .cursor-dot {
      border-radius: 0;
    }
    
    #game-cursor.cursor-nes .cursor-ring { border-color: #ff0000; border-width: 2px; }
    #game-cursor.cursor-gb .cursor-ring { border-color: #8bac0f; }

    #game-cursor.cursor-ps1 .cursor-ring { border-color: #22d3ee; border-style: dashed; }
    #game-cursor.cursor-ps1 .cursor-dot { background-color: #22d3ee; }

    #game-cursor.cursor-ps5 .cursor-ring { 
      border-color: #6366f1; 
      box-shadow: 0 0 15px rgba(99, 102, 241, 0.5);
      animation: pulse 2s infinite;
    }

    #game-cursor.cursor-hd .cursor-ring { border-color: #8eb837; border-width: 2px; }

    /* Interactive Hover States */
    a:hover ~ #game-cursor .cursor-ring, 
    button:hover ~ #game-cursor .cursor-ring {
      transform: scale(1.5);
      border-color: white !important;
    }
  </style>

</body>
</html>