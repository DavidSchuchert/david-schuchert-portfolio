---
---

<section class="retro-hero w-full min-h-[100svh] relative flex items-center justify-center overflow-hidden bg-black text-white p-6">
  
  <!-- CRT Screen Effects -->
  <div class="crt-overlay pointer-events-none absolute inset-0 z-50"></div>
  <div class="scanlines pointer-events-none absolute inset-0 z-40"></div>

  <div class="retro-container relative z-30 max-w-4xl w-full text-center flex flex-col items-center">
    
    <div class="mb-12 animate-pulse-slow">
      <span class="text-xs md:text-sm text-green-500 pixel-font tracking-widest">CREDIT 99</span>
    </div>

    <h1 class="pixel-font font-black text-3xl md:text-5xl lg:text-7xl text-blue-500 mb-6 retro-shadow leading-tight">
      PLAYER 1<br/>
      <span class="text-white">DAVID</span>
    </h1>

    <p class="pixel-font text-xs md:text-sm text-gray-300 mb-16 leading-relaxed max-w-xl">
      CLASS: FULL-STACK MAGE<br/><br/>
      PRESS START TO BEGIN...
    </p>

    <a href="#era-16bit" class="pixel-btn group relative inline-block px-8 py-4 bg-transparent border-4 border-white text-white pixel-font text-sm uppercase hover:bg-white hover:text-black hover:border-black transition-colors">
      <span class="absolute -left-8 top-1/2 -translate-y-1/2 opacity-0 group-hover:opacity-100 transition-opacity text-xl">▶</span>
      INSERT COIN
      <span class="absolute -right-8 top-1/2 -translate-y-1/2 opacity-0 group-hover:opacity-100 transition-opacity text-xl">◀</span>
    </a>

  </div>
</section>

<style>
  .pixel-font {
    font-family: 'Press Start 2P', monospace;
  }

  .retro-shadow {
    text-shadow: 4px 4px 0px #ff0055, -4px -4px 0px #00ffff;
  }

  .animate-pulse-slow {
    animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }

  /* CRT CURVE */
  .retro-hero {
    box-shadow: inset 0 0 100px rgba(0,0,0,0.9);
  }

  /* CRT OVERLAY (Vignette & Flicker) */
  .crt-overlay {
    background: radial-gradient(circle, rgba(0,0,0,0) 60%, rgba(0,0,0,0.6) 100%);
    animation: flicker 0.15s infinite;
  }

  /* CLASSIC SCANLINES */
  .scanlines {
    background: linear-gradient(
      rgba(18, 16, 16, 0) 50%,
      rgba(0, 0, 0, 0.25) 50%
    );
    background-size: 100% 4px;
    z-index: 100;
  }

  @keyframes flicker {
    0% { opacity: 0.95; }
    50% { opacity: 0.85; }
    100% { opacity: 0.95; }
  }
</style>