---
const roles = ['Developer', 'Dozent', 'Gaming-Opa 🍻', 'Problem-Löser'];
---

<section class="min-h-screen flex items-center justify-center relative overflow-hidden pt-16">
  <div class="absolute inset-0 opacity-[0.03] dark:opacity-[0.05] font-mono text-amber-500 select-none pointer-events-none overflow-hidden">
    <pre class="absolute top-10 left-4 text-xs leading-none">
    ┌─────────────────────────────┐
    │ > Web Developer Portfolio_  │
    │   Status: Online 🎮         │
    │   Location: Bad Hersfeld 🍻│
    └─────────────────────────────┘
    </pre>
    <pre class="absolute bottom-20 right-4 text-xs leading-none">
    {`   \\|/
    --@--
    / | \\`}</pre>
  </div>

  <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-amber-500/10 rounded-full blur-3xl animate-pulse"></div>
  <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-orange-500/10 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s"></div>

  <div class="relative z-10 text-center px-4 max-w-4xl mx-auto">
    <div class="ascii-box inline-block mb-8 animate-fade-in">
      <span class="text-amber-500">$</span> whoami<br/>
      <span class="text-emerald-400">=&gt;</span> David Schuchert
    </div>

    <h1 class="text-5xl sm:text-6xl md:text-7xl font-black mb-4 animate-slide-up">
      <span class="gradient-text">Code. Kurse. Controller.</span>
    </h1>
    <p class="text-xl sm:text-2xl text-gray-600 dark:text-gray-400 mb-2 animate-slide-up animate-delay-100 font-mono">
      Hi, ich bin <span class="text-amber-500 font-bold">David</span> — dein
    </p>
    <div class="h-12 mb-8 animate-slide-up animate-delay-200">
      <span id="role-text" class="text-2xl sm:text-3xl font-bold text-emerald-400"></span><span class="text-2xl sm:text-3xl text-amber-500 animate-blink">|</span>
    </div>

    <p class="text-lg text-gray-500 dark:text-gray-400 mb-12 max-w-2xl mx-auto animate-slide-up animate-delay-300 leading-relaxed">
      Full-Stack mit TypeScript, React & Laravel.<br class="hidden sm:block"/>
      <span class="text-amber-500">Dozent bei der DBE-Academy.</span> Und ab und zu ein vernünftiges Gaming-Setup. 🎮
    </p>

    <div class="flex flex-wrap justify-center gap-4 mb-16 animate-slide-up animate-delay-400">
      <a href="#projects" class="btn-primary group">
        <span class="flex items-center gap-2">
          <span>🚀</span> Meine Projekte
        </span>
      </a>
    </div>

    <div class="flex justify-center gap-5 animate-slide-up animate-delay-500">
      <a href="https://github.com/DavidSchuchert" target="_blank" rel="noopener noreferrer"
         class="group p-3 rounded-xl bg-gray-100 dark:bg-gray-800 hover:bg-amber-500 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:shadow-amber-500/20">
        <svg class="w-6 h-6 group-hover:text-white transition-colors" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
        </svg>
      </a>
      <a href="https://linkedin.com/in/david-schuchert-0ab892283/" target="_blank" rel="noopener noreferrer"
         class="group p-3 rounded-xl bg-gray-100 dark:bg-gray-800 hover:bg-blue-600 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:shadow-blue-500/20">
        <svg class="w-6 h-6 group-hover:text-white transition-colors" fill="currentColor" viewBox="0 0 24 24">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>
      <a href="https://www.xing.com/profile/David_Schuchert" target="_blank" rel="noopener noreferrer"
         class="group p-3 rounded-xl bg-gray-100 dark:bg-gray-800 hover:bg-green-600 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:shadow-green-500/20">
        <svg class="w-6 h-6 group-hover:text-white transition-colors" fill="currentColor" viewBox="0 0 24 24">
          <path d="M15.3 0H8.7C3.66 0 0 3.66 0 8.7v6.6C0 20.34 3.66 24 8.7 24h6.6c5.04 0 8.7-3.66 8.7-8.7V8.7C24 3.66 20.34 0 15.3 0zm3.06 17.5h-1.66V9.06h1.66v8.44zm-2.64-9.82c-.84 0-1.5-.66-1.5-1.5s.66-1.5 1.5-1.5 1.5.66 1.5 1.5-.66 1.5-1.5 1.5zm-4.14 9.82H6.86V9.06h4.92v8.44z"/>
        </svg>
      </a>
    </div>

    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <a href="#about" class="text-gray-400 hover:text-amber-500 transition-colors" aria-label="Nach unten scrollen">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
        </svg>
      </a>
    </div>
  </div>
</section>

<script>
  const roles = ['Developer', 'Dozent', 'Gaming-Opa 🍻', 'Problem-Löser'];
  let roleIndex = 0;
  let charIndex = 0;
  let isDeleting = false;
  const roleText = document.getElementById('role-text');

  function type() {
    const current = roles[roleIndex];

    if (isDeleting) {
      roleText!.textContent = current.substring(0, charIndex - 1);
      charIndex--;
    } else {
      roleText!.textContent = current.substring(0, charIndex + 1);
      charIndex++;
    }

    if (!isDeleting && charIndex === current.length) {
      setTimeout(() => { isDeleting = true; type(); }, 1800);
      return;
    }

    if (isDeleting && charIndex === 0) {
      isDeleting = false;
      roleIndex = (roleIndex + 1) % roles.length;
      setTimeout(type, 300);
      return;
    }

    setTimeout(type, isDeleting ? 50 : 120);
  }

  type();
</script>
