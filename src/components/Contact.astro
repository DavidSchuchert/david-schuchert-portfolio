<section id="era-nextgen" class="aaa-lobby w-full min-h-[100svh] bg-[#000] py-20 px-4 md:px-8 flex items-center justify-center relative overflow-hidden">
  
  <!-- NEXT-GEN VISUALS: Dynamic Neon Particles -->
  <div class="absolute inset-0 z-0">
    <div class="absolute top-[10%] left-[20%] w-[400px] h-[400px] bg-indigo-600/20 rounded-full blur-[120px] animate-pulse"></div>
    <div class="absolute bottom-[10%] right-[20%] w-[350px] h-[350px] bg-magenta-600/10 rounded-full blur-[100px] animate-pulse delay-1000"></div>
    <!-- Fine Grid overlay -->
    <div class="absolute inset-0 opacity-[0.03] pointer-events-none bg-[url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSI0MCIgaGVpZ2h0PSI0MCIgdmlld0JveD0iMCAwIDQwIDQwIj48cmVjdCB3aWR0aD0iNDAiIGhlaWdodD0iNDAiIGZpbGw9Im5vbmUiIHN0cm9rZT0id2hpdGUiIHN0cm9rZS13aWR0aD0iMSIgc3Ryb2tlLW9wYWNpdHk9IjEiLz48L3N2Zz4=')]"></div>
  </div>

  <!-- SESSION JOINED NOTIFICATION -->
  <div id="matchmaking-status" class="absolute top-10 left-10 z-50 flex items-center gap-4 opacity-0 -translate-x-10 transition-all duration-1000">
    <div class="w-2 h-2 bg-green-500 rounded-full animate-ping"></div>
    <div class="flex flex-col">
       <span class="text-[10px] text-white font-black tracking-[0.4em] uppercase">Session Joined</span>
       <span class="text-[8px] text-white/40 font-mono">LOBBY_ID: DAVID_SCHUCHERT_v3.0.21</span>
    </div>
  </div>

  <div class="max-w-6xl w-full relative z-10 flex flex-col md:flex-row items-center gap-12">
    
    <!-- Next-Gen Player Card (Glassmorphism) -->
    <div class="flex-1 w-full bg-white/[0.03] backdrop-blur-3xl border border-white/10 rounded-2xl p-1 shadow-2xl relative overflow-hidden group">
      <div class="absolute inset-0 bg-gradient-to-br from-indigo-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
      
      <div class="relative bg-black/60 rounded-xl p-8 md:p-12 border border-white/5">
        <div class="flex flex-col md:flex-row items-center md:items-start gap-8">
          
          <!-- Avatar with High-End Ring -->
          <div class="relative">
            <div class="w-32 h-32 md:w-40 md:h-40 rounded-full bg-gradient-to-tr from-indigo-500 via-purple-500 to-pink-500 p-1 group-hover:rotate-12 transition-transform duration-1000 shadow-[0_0_50px_rgba(99,102,241,0.3)]">
               <div class="w-full h-full rounded-full bg-black flex items-center justify-center overflow-hidden">
                  <img src="https://avatars.githubusercontent.com/u/142668300?v=4" alt="David Schuchert" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-1000" />
               </div>
            </div>
            <div class="absolute -bottom-2 -right-2 bg-green-500 w-6 h-6 rounded-full border-4 border-black animate-pulse"></div>
          </div>

          <div class="flex-1 text-center md:text-left">
            <div class="flex flex-wrap items-center justify-center md:justify-start gap-4 mb-4">
               <span class="px-3 py-1 bg-white/10 text-white text-[10px] font-black tracking-widest rounded-full border border-white/20">PRESTIGE MASTER</span>
               <span class="px-3 py-1 bg-indigo-600/20 text-indigo-400 text-[10px] font-black tracking-widest rounded-full border border-indigo-500/30">LEVEL 99</span>
            </div>
            <h2 class="text-4xl md:text-6xl font-black text-white uppercase tracking-tighter mb-4 italic leading-none">
              David Schuchert
            </h2>
            <p class="text-gray-400 text-sm md:text-base leading-relaxed font-medium">
              Bereit für den nächsten Raid auf komplexe Architekturen.<br class="hidden md:block" />
              Lade mich in deine Party ein, um das Backend zu dominieren.
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Lobby Menu -->
    <div class="md:w-80 w-full flex flex-col gap-3">
      <h3 class="text-[10px] text-indigo-400 uppercase tracking-[0.5em] mb-2 font-black pl-4 border-l-2 border-indigo-500">Party Actions</h3>
      
      <a href="mailto:davidschuchert@icloud.com" class="group relative w-full overflow-hidden rounded-xl">
        <div class="absolute inset-0 bg-gradient-to-r from-indigo-600 to-purple-600 opacity-80 transition-transform duration-500 group-hover:scale-105"></div>
        <div class="relative p-6 flex items-center justify-between">
          <span class="text-white font-black tracking-widest text-sm italic uppercase">Invite To Party</span>
          <span class="text-[10px] text-white/60 font-mono">E-MAIL</span>
        </div>
      </a>

      <a href="https://github.com/DavidSchuchert" target="_blank" class="group relative w-full overflow-hidden rounded-xl border border-white/10 hover:border-white/30 transition-all">
        <div class="absolute inset-0 bg-white/5 opacity-0 group-hover:opacity-100 transition-all"></div>
        <div class="relative p-6 flex items-center justify-between">
          <span class="text-white font-black tracking-widest text-sm italic uppercase">View Profile</span>
          <span class="text-[10px] text-white/40 font-mono">GITHUB</span>
        </div>
      </a>

      <a href="https://www.linkedin.com/in/david-schuchert-0ab892283/" target="_blank" class="group relative w-full overflow-hidden rounded-xl border border-white/10 hover:border-white/30 transition-all">
        <div class="absolute inset-0 bg-white/5 opacity-0 group-hover:opacity-100 transition-all"></div>
        <div class="relative p-6 flex items-center justify-between">
          <span class="text-white font-black tracking-widest text-sm italic uppercase">Add Friend</span>
          <span class="text-[10px] text-white/40 font-mono">LINKEDIN</span>
        </div>
      </a>
    </div>

  </div>

  <!-- Decorative HUD Scroll indicator -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 opacity-20 hidden md:block">
     <div class="w-[1px] h-20 bg-gradient-to-b from-white to-transparent"></div>
  </div>
</section>

<style>
  .aaa-lobby {
    font-family: 'Outfit', sans-serif;
  }

  @keyframes pulse {
    0%, 100% { opacity: 0.1; transform: scale(1); }
    50% { opacity: 0.2; transform: scale(1.1); }
  }
</style>

<script>
  // Simple entry animation trigger
  const lobbyObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const status = document.getElementById('matchmaking-status');
        if (status) {
          status.style.opacity = '1';
          status.style.transform = 'translateX(0)';
        }
      }
    });
  }, { threshold: 0.5 });

  const nextGenSect = document.getElementById('era-nextgen');
  if (nextGenSect) lobbyObserver.observe(nextGenSect);
</script>
