---
---

<section id="contact" class="py-20 px-4">
  <div class="max-w-3xl mx-auto">
    <!-- Section header -->
    <div class="mb-12 text-center">
      <div class="ascii-box inline-block mb-4">
        <span class="text-amber-500">$</span> send_message --to david
      </div>
      <h2 class="section-title">Kontakt</h2>
      <p class="text-gray-500 dark:text-gray-400 mt-2">Lass uns quatschen! 🚀</p>
    </div>

    <!-- Contact Grid -->
    <div class="grid md:grid-cols-2 gap-8">
      <!-- Direct Contact -->
      <div class="space-y-6">
        <h3 class="text-lg font-bold text-gray-900 dark:text-white">Direkt</h3>

        <a href="mailto:david@example.com" class="block p-6 bg-white dark:bg-gray-900 rounded-xl shadow-lg hover:shadow-xl transition-all group border border-gray-200 dark:border-gray-800 hover:border-amber-500">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-lg bg-amber-500/10 flex items-center justify-center group-hover:bg-amber-500 transition-colors">
              <span class="text-2xl">📧</span>
            </div>
            <div>
              <p class="text-sm text-gray-500">Email</p>
              <p class="font-semibold text-gray-900 dark:text-white">david@dbe.academy</p>
            </div>
          </div>
        </a>

        <a href="https://linkedin.com/in/david-schuchert-0ab892283/" target="_blank" rel="noopener noreferrer"
           class="block p-6 bg-white dark:bg-gray-900 rounded-xl shadow-lg hover:shadow-xl transition-all group border border-gray-200 dark:border-gray-800 hover:border-amber-500">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-lg bg-blue-500/10 flex items-center justify-center group-hover:bg-blue-500 transition-colors">
              <span class="text-2xl">💼</span>
            </div>
            <div>
              <p class="text-sm text-gray-500">LinkedIn</p>
              <p class="font-semibold text-gray-900 dark:text-white">David Schuchert</p>
            </div>
          </div>
        </a>

        <a href="https://github.com/davidschuchert" target="_blank" rel="noopener noreferrer"
           class="block p-6 bg-white dark:bg-gray-900 rounded-xl shadow-lg hover:shadow-xl transition-all group border border-gray-200 dark:border-gray-800 hover:border-amber-500">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-lg bg-gray-800/10 flex items-center justify-center group-hover:bg-gray-900 transition-colors">
              <span class="text-2xl">🐙</span>
            </div>
            <div>
              <p class="text-sm text-gray-500">GitHub</p>
              <p class="font-semibold text-gray-900 dark:text-white">davidschuchert</p>
            </div>
          </div>
        </a>
      </div>

      <!-- Contact Form -->
      <div class="bg-white dark:bg-gray-900 rounded-xl shadow-lg p-8 border border-gray-200 dark:border-gray-800">
        <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-6">Nachricht senden</h3>

        <form class="space-y-4" action="https://formspree.io/f/yourformid" method="POST">
          <div>
            <label for="name" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Name</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-amber-500 focus:border-transparent transition-all"
              placeholder="Dein Name"
            />
          </div>

          <div>
            <label for="email" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-amber-500 focus:border-transparent transition-all"
              placeholder="deine@email.de"
            />
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Nachricht</label>
            <textarea
              id="message"
              name="message"
              rows="4"
              required
              class="w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-amber-500 focus:border-transparent transition-all resize-none"
              placeholder="Was willst du mir sagen?"
            ></textarea>
          </div>

          <button type="submit" class="w-full btn-primary">
            <span class="flex items-center justify-center gap-2">
              <span>🚀</span> Absenden
            </span>
          </button>
        </form>
      </div>
    </div>
  </div>
</section>