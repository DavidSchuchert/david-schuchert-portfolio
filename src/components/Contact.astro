---
---

<section class="next-gen-contact w-full relative overflow-hidden rounded-[2rem] bg-[#020202] py-24 px-8 md:px-16 border border-[#222] shadow-[0_0_100px_rgba(0,0,0,1)]">
  
  <!-- Subtle top-down lighting (Raytraced vibe) -->
  <div class="absolute top-0 inset-x-0 mx-auto w-1/2 h-px bg-gradient-to-r from-transparent via-white/50 to-transparent"></div>
  <div class="absolute -top-32 inset-x-0 mx-auto w-3/4 h-64 bg-white/5 blur-[80px] rounded-full pointer-events-none"></div>

  <div class="max-w-4xl mx-auto flex flex-col items-center text-center relative z-10">
    
    <div class="inline-flex items-center gap-3 px-4 py-2 rounded-full bg-white/[0.03] border border-white/10 backdrop-blur-md mb-12">
      <span class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
      </span>
      <span class="text-xs uppercase tracking-widest text-gray-400 font-medium">System Online • Ready for Input</span>
    </div>

    <h2 class="text-5xl md:text-7xl font-black text-transparent bg-clip-text bg-gradient-to-b from-white to-gray-500 mb-6 tracking-tighter">
      Initiate Contact
    </h2>
    
    <p class="text-gray-400 text-lg max-w-2xl text-balance mb-16 font-light">
      Gute Architektur entsteht nicht zufällig. Ping mich an, wenn du Performance, Stabilität und ein Level-Up für dein Stack brauchst.
    </p>

    <!-- The Next-Gen Action Button -->
    <a href="mailto:david@dbe.academy" class="group relative px-12 py-5 rounded-2xl bg-white/[0.02] border border-white/10 overflow-hidden hover:scale-105 transition-transform duration-500 hover:border-white/30 hover:bg-white/[0.05]">
      <!-- Animated glass sweep -->
      <div class="absolute inset-0 -translate-x-full bg-gradient-to-r from-transparent via-white/10 to-transparent group-hover:animate-[shimmer_1.5s_infinite]"></div>
      
      <span class="relative z-10 flex items-center gap-4 text-white font-medium text-lg tracking-wide">
        <svg class="w-6 h-6 text-gray-400 group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        david@dbe.academy
      </span>
    </a>

  </div>
</section>

<style>
  @keyframes shimmer {
    100% { transform: translateX(100%); }
  }
</style>
