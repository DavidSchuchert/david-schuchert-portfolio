---
---

<section class="aaa-lobby w-full min-h-[60vh] bg-[#0b0c10] py-16 px-4 md:px-8 flex items-center justify-center relative overflow-hidden">
  
  <!-- Subtle diagonal pattern background typical in modern shooters (Valorant, CoD) -->
  <div class="absolute inset-0 opacity-10 pointer-events-none" style="background-image: repeating-linear-gradient(45deg, #ffffff 0, #ffffff 1px, transparent 1px, transparent 10px);"></div>
  <div class="absolute inset-0 bg-gradient-to-t from-[#0b0c10] to-transparent"></div>

  <div class="max-w-5xl w-full relative z-10 flex flex-col md:flex-row items-stretch gap-8">
    
    <!-- Player Card -->
    <div class="flex-1 bg-[#151720] border border-[#2a2c38] rounded-sm flex flex-col transform transition-transform hover:-translate-y-1 hover:shadow-[0_10px_30px_rgba(99,102,241,0.15)] group relative overflow-hidden">
      <!-- Banner/Header graphic -->
      <div class="h-32 w-full bg-gradient-to-r from-indigo-900 to-[#151720] relative">
        <div class="absolute top-4 right-4 bg-black/50 px-2 py-1 flex items-center gap-2 rounded-sm border border-white/10">
          <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
          <span class="text-[10px] text-white tracking-widest font-bold">ONLINE</span>
        </div>
      </div>

      <div class="px-8 pb-8 -mt-12 flex flex-col relative z-20">
        <div class="w-24 h-24 rounded-sm border-4 border-[#151720] bg-gray-800 shadow-xl overflow-hidden mb-4">
          <img src="https://avatars.githubusercontent.com/u/142668300?v=4" alt="David Schuchert" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500" />
        </div>
        
        <div class="flex items-center gap-3">
          <span class="px-2 py-1 bg-indigo-600 text-white text-xs font-black tracking-widest rounded-sm">Lvl 99</span>
          <h2 class="text-3xl font-black text-white uppercase tracking-wider">
            David Schuchert
          </h2>
        </div>
        <span class="text-indigo-400 font-medium tracking-widest text-sm uppercase mt-1 mb-6">[DEV] CLAN</span>

        <p class="text-gray-400 text-sm leading-relaxed max-w-md">
          Bereit für den nächsten Raid auf komplexe Web-Architekturen. Lade mich in deine Party ein, um das Backend zu dominieren.
        </p>
      </div>
    </div>

    <!-- Lobby Actions -->
    <div class="md:w-80 flex flex-col gap-3 justify-center">
      <h3 class="text-xs text-gray-500 uppercase tracking-[0.2em] mb-2 font-bold pl-2">Social Menu</h3>
      
      <!-- Action Button 1 -->
      <a href="mailto:kontakt@david-schuchert.de" class="lobby-action group relative w-full bg-[#151720] border-l-4 border-transparent hover:border-indigo-500 hover:bg-[#1a1d28] p-4 flex items-center justify-between transition-all">
        <span class="text-white font-bold tracking-wide group-hover:translate-x-2 transition-transform">
          INVITE TO PARTY
        </span>
        <svg class="w-5 h-5 text-gray-500 group-hover:text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      </a>

      <!-- Action Button 2 -->
      <a href="https://github.com/DavidSchuchert" target="_blank" class="lobby-action group relative w-full bg-[#151720] border-l-4 border-transparent hover:border-white hover:bg-[#1a1d28] p-4 flex items-center justify-between transition-all">
        <span class="text-white font-bold tracking-wide group-hover:translate-x-2 transition-transform">
          VIEW PROFILE
        </span>
        <span class="text-xs text-gray-500 uppercase font-bold tracking-widest">GitHub</span>
      </a>

      <a href="https://www.linkedin.com/in/david-schuchert-0ab892283/" target="_blank" class="lobby-action group relative w-full bg-[#151720] border-l-4 border-transparent hover:border-blue-500 hover:bg-[#1a1d28] p-4 flex items-center justify-between transition-all">
        <span class="text-white font-bold tracking-wide group-hover:translate-x-2 transition-transform">
          SEND FRIEND REQUEST
        </span>
        <span class="text-xs text-gray-500 uppercase font-bold tracking-widest">LinkedIn</span>
      </a>
    </div>

  </div>
</section>

<style>
  .aaa-lobby {
    font-family: 'Inter', sans-serif;
  }
  
  .lobby-action {
    clip-path: polygon(0 0, 100% 0, 100% calc(100% - 10px), calc(100% - 10px) 100%, 0 100%);
  }
</style>
