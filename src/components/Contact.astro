---
---

<section id="contact" class="py-20 px-4" aria-labelledby="contact-heading">
  <div class="max-w-3xl mx-auto">
    <!-- Section header -->
    <div class="mb-12 text-center">
      <div class="ascii-box inline-block mb-4" aria-hidden="true">
        <span class="text-amber-500">$</span> send_message --to david
      </div>
      <h2 id="contact-heading" class="section-title">Kontakt</h2>
      <p class="text-gray-500 dark:text-gray-400 mt-2">Lass uns quatschen.</p>
    </div>

    <!-- Response time banner -->
    <div class="mb-10 text-center">
      <div class="inline-flex items-center gap-2 px-4 py-2 bg-emerald-50 dark:bg-emerald-900/20 border border-emerald-200 dark:border-emerald-800 rounded-full text-sm text-emerald-700 dark:text-emerald-300" role="status" aria-live="polite">
        <span class="relative flex h-2 w-2" aria-hidden="true">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
        </span>
        Ich antworte innerhalb von 24h — versprochen.
      </div>
    </div>

    <!-- Contact Grid -->
    <div class="grid md:grid-cols-2 gap-8">
      <!-- Direct Contact -->
      <div class="space-y-4">
        <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-4">Direkt</h3>

        <a
          href="mailto:david@dbe.academy"
          class="block p-5 bg-white dark:bg-gray-900 rounded-xl shadow-lg hover:shadow-xl transition-all group border border-gray-200 dark:border-gray-800 hover:border-amber-500 min-h-[88px] flex items-center"
          aria-label="Email an David Schuchert: david@dbe.academy"
        >
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-lg bg-amber-500/10 flex items-center justify-center group-hover:bg-amber-500 transition-colors" aria-hidden="true">
              <svg class="w-6 h-6 text-amber-500 group-hover:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </div>
            <div>
              <p class="text-sm text-gray-500">Email</p>
              <p class="font-semibold text-gray-900 dark:text-white">david@dbe.academy</p>
            </div>
          </div>
        </a>

        <a
          href="https://linkedin.com/in/david-schuchert-0ab892283/"
          target="_blank"
          rel="noopener noreferrer"
          class="block p-5 bg-white dark:bg-gray-900 rounded-xl shadow-lg hover:shadow-xl transition-all group border border-gray-200 dark:border-gray-800 hover:border-blue-500 min-h-[88px] flex items-center"
          aria-label="LinkedIn Profil von David Schuchert (öffnet in neuem Tab)"
        >
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-lg bg-blue-500/10 flex items-center justify-center group-hover:bg-blue-600 transition-colors" aria-hidden="true">
              <svg class="w-6 h-6 text-blue-500 group-hover:text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </div>
            <div>
              <p class="text-sm text-gray-500">LinkedIn</p>
              <p class="font-semibold text-gray-900 dark:text-white">David Schuchert</p>
            </div>
          </div>
        </a>

        <a
          href="https://www.xing.com/profile/David_Schuchert"
          target="_blank"
          rel="noopener noreferrer"
          class="block p-5 bg-white dark:bg-gray-900 rounded-xl shadow-lg hover:shadow-xl transition-all group border border-gray-200 dark:border-gray-800 hover:border-green-600 min-h-[88px] flex items-center"
          aria-label="Xing Profil von David Schuchert (öffnet in neuem Tab)"
        >
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-lg bg-green-500/10 flex items-center justify-center group-hover:bg-green-600 transition-colors" aria-hidden="true">
              <svg class="w-6 h-6 text-green-500 group-hover:text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M15.3 0H8.7C3.66 0 0 3.66 0 8.7v6.6C0 20.34 3.66 24 8.7 24h6.6c5.04 0 8.7-3.66 8.7-8.7V8.7C24 3.66 20.34 0 15.3 0zm3.06 17.5h-1.66V9.06h1.66v8.44zm-2.64-9.82c-.84 0-1.5-.66-1.5-1.5s.66-1.5 1.5-1.5 1.5.66 1.5 1.5-.66 1.5-1.5 1.5zm-4.14 9.82H6.86V9.06h4.92v8.44z"/></svg>
            </div>
            <div>
              <p class="text-sm text-gray-500">Xing</p>
              <p class="font-semibold text-gray-900 dark:text-white">David Schuchert</p>
            </div>
          </div>
        </a>

        <a
          href="https://github.com/DavidSchuchert"
          target="_blank"
          rel="noopener noreferrer"
          class="block p-5 bg-white dark:bg-gray-900 rounded-xl shadow-lg hover:shadow-xl transition-all group border border-gray-200 dark:border-gray-800 hover:border-gray-800 min-h-[88px] flex items-center"
          aria-label="GitHub Profil von David Schuchert (öffnet in neuem Tab)"
        >
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-lg bg-gray-800/10 dark:bg-gray-800 flex items-center justify-center group-hover:bg-gray-900 transition-colors" aria-hidden="true">
              <svg class="w-6 h-6 text-gray-700 dark:text-gray-300 group-hover:text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
            </div>
            <div>
              <p class="text-sm text-gray-500">GitHub</p>
              <p class="font-semibold text-gray-900 dark:text-white">davidschuchert</p>
            </div>
          </div>
        </a>
      </div>

      <!-- Contact Form -->
      <div class="bg-white dark:bg-gray-900 rounded-xl shadow-lg p-8 border border-gray-200 dark:border-gray-800">
        <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-2">Schreib mir eine Nachricht</h3>
        <p class="text-sm text-gray-500 dark:text-gray-400 mb-6">Frage zu einem Projekt? Zusammenarbeit? Oder einfach hallo sagen?</p>

        <form class="space-y-4" action="https://formspree.io/f/yourformid" method="POST" novalidate aria-label="Kontaktformular">
          <div>
            <label for="name" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
              Name <span class="text-red-500" aria-label="erforderlich">*</span>
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              autocomplete="name"
              aria-required="true"
              class="w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-amber-500 focus:border-transparent transition-all min-h-[44px]"
              placeholder="Dein Name"
            />
          </div>

          <div>
            <label for="email" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
              Email <span class="text-red-500" aria-label="erforderlich">*</span>
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              autocomplete="email"
              aria-required="true"
              class="w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-amber-500 focus:border-transparent transition-all min-h-[44px]"
              placeholder="deine@email.de"
            />
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
              Nachricht <span class="text-red-500" aria-label="erforderlich">*</span>
            </label>
            <textarea
              id="message"
              name="message"
              rows="4"
              required
              aria-required="true"
              class="w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-amber-500 focus:border-transparent transition-all resize-none"
              placeholder="Was willst du mir sagen?"
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full btn-primary btn-ripple min-h-[44px] flex items-center justify-center"
          >
            <span class="flex items-center justify-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
              Absenden
            </span>
          </button>

          <p class="text-xs text-gray-400 text-center" aria-hidden="true">
            * Pflichtfelder
          </p>
        </form>
      </div>
    </div>
  </div>
</section>
