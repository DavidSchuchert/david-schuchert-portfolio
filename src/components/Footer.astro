---
const currentYear = new Date().getFullYear();
---

<footer class="w-full py-20 bg-black/40 border-t border-white/5 relative overflow-hidden">
  
  <!-- Subtle Gradient Background to blend with Next-Gen section -->
  <div class="absolute inset-0 bg-gradient-to-b from-transparent to-blue-950/20 opacity-30 pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-4 md:px-8 flex flex-col items-center relative z-10">
    
    <div class="flex items-center gap-4 mb-8">
       <div class="w-10 h-[1px] bg-white/10"></div>
       <button id="scroll-to-top" class="w-10 h-10 rounded-full bg-white/10 border border-white/30 flex items-center justify-center p-2 hover:bg-white/20 hover:border-white/50 transition-all group" aria-label="Scroll to top">
         <svg class="text-white group-hover:-translate-y-1 transition-all" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L4.5 20.29L5.21 21L12 18L18.79 21L19.5 20.29L12 2Z"/></svg>
       </button>
       <div class="w-10 h-[1px] bg-white/10"></div>
    </div>

    <!-- Speed Lines Overlay (Hidden by default) -->
    <div id="speed-lines" class="fixed inset-0 pointer-events-none z-[1000] opacity-0 transition-opacity duration-300">
      <div class="absolute inset-0 bg-white/5"></div>
      <div class="line-container absolute inset-0 overflow-hidden">
        {Array.from({ length: 40 }).map((_, i) => (
          <div 
            class="speed-line absolute bg-white/20" 
            style={`
              left: ${Math.random() * 100}%; 
              top: -20%; 
              width: 1px; 
              height: ${20 + Math.random() * 30}%; 
              animation: drop ${0.2 + Math.random() * 0.3}s linear infinite; 
              animation-delay: ${Math.random() * 0.5}s;
            `}
          ></div>
        ))}
      </div>
    </div>

    <div class="text-[10px] font-mono tracking-[0.5em] uppercase text-white/40 mb-4">
      System Ready • Player 1 Authenticated
    </div>
    
    <p class="text-white/20 text-[10px] uppercase font-bold tracking-widest mb-10 text-center">
      © {currentYear} David Schuchert • BAD HERSFELD, DE • ALL RIGHTS RESERVED
    </p>

    <!-- ... rest of the component -->
    <div class="flex flex-wrap justify-center gap-8 mb-4">
      <a href="/impressum" class="group flex items-center gap-2">
        <div class="w-6 h-6 rounded-sm border border-white/20 flex items-center justify-center text-[10px] font-black text-white/40 group-hover:border-white/60 group-hover:text-white transition-all">L</div>
        <span class="text-[10px] font-bold uppercase text-white/20 tracking-widest group-hover:text-white transition-all">LEGAL / IMPRESSUM</span>
      </a>
      <a href="/datenschutz" class="group flex items-center gap-2">
        <div class="w-6 h-6 rounded-sm border border-white/20 flex items-center justify-center text-[10px] font-black text-white/40 group-hover:border-white/60 group-hover:text-white transition-all">P</div>
        <span class="text-[10px] font-bold uppercase text-white/20 tracking-widest group-hover:text-white transition-all">PRIVACY / DATENSCHUTZ</span>
      </a>
    </div>

    <div class="mt-12 text-[8px] text-white/10 uppercase tracking-[1em] italic">
       Execution Engine: Astro x Vite
    </div>

  </div>
</footer>

<script>
  const scrollBtn = document.getElementById('scroll-to-top');
  const speedLines = document.getElementById('speed-lines');

  if (scrollBtn && speedLines) {
    scrollBtn.addEventListener('click', () => {
      // Show speed lines
      speedLines.style.opacity = '1';
      
      // Smooth scroll
      window.scrollTo({
        top: 0,
        behavior: 'smooth'
      });

      // Hide speed lines after a delay (enough for the scroll to finish)
      setTimeout(() => {
        speedLines.style.opacity = '0';
      }, 800);
    });
  }
</script>

<style>
  footer {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
  }

  .speed-line {
    border-radius: 9999px;
  }

  @keyframes drop {
    0% { transform: translateY(-100%); opacity: 0; }
    50% { opacity: 1; }
    100% { transform: translateY(500%); opacity: 0; }
  }
</style>
