---
const currentYear = new Date().getFullYear();
---

<footer class="w-full py-12 mt-12 border-t border-white/5">
  <div class="max-w-7xl mx-auto px-4 md:px-8 text-center flex flex-col items-center">
    
    <span class="w-8 h-8 rounded-full bg-white/5 flex items-center justify-center mb-6">
      <span class="w-2 h-2 rounded-full bg-accent-500 shadow-[0_0_10px_rgba(99,102,241,0.8)]"></span>
    </span>

    <div class="text-xs font-mono tracking-widest uppercase text-surface-500 mb-2">
      Creative Developer
    </div>
    
    <p class="text-surface-600 text-xs">
      © {currentYear} David Schuchert. All rights reserved. Built with Astro & Tailwind.
    </p>

  </div>
</footer>
