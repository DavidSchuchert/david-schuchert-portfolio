---
const currentYear = new Date().getFullYear();
---

<footer class="w-full py-20 bg-black/40 border-t border-white/5 relative overflow-hidden">
  
  <!-- Subtle Gradient Background to blend with Next-Gen section -->
  <div class="absolute inset-0 bg-gradient-to-b from-transparent to-blue-950/20 opacity-30 pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-4 md:px-8 flex flex-col items-center relative z-10">
    
    <div class="flex items-center gap-4 mb-8">
       <div class="w-10 h-[1px] bg-white/10"></div>
       <button id="scroll-to-top" class="w-12 h-12 rounded-full bg-[#00ffff] border-2 border-white flex items-center justify-center p-2 hover:scale-110 active:scale-95 transition-all group shadow-[0_0_20px_rgba(0,255,255,0.5)] relative z-[100]" aria-label="Scroll to top">
         <svg class="w-6 h-6 text-black group-hover:-translate-y-1 transition-all" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L4.5 20.29L5.21 21L12 18L18.79 21L19.5 20.29L12 2Z"/></svg>
       </button>
       <div class="w-10 h-[1px] bg-white/10"></div>
    </div>

    <!-- Speed Lines Overlay (Hidden by default) -->
    <div id="speed-lines" class="fixed inset-0 pointer-events-none z-[1000] opacity-0 transition-opacity duration-300">
      <div class="absolute inset-0 bg-white/5"></div>
      <div class="line-container absolute inset-0 overflow-hidden">
        {Array.from({ length: 40 }).map((_, i) => (
          <div 
            class="speed-line absolute bg-white/20" 
            style={`
              left: ${Math.random() * 100}%; 
              top: -20%; 
              width: 1px; 
              height: ${20 + Math.random() * 30}%; 
              animation: drop ${0.2 + Math.random() * 0.3}s linear infinite; 
              animation-delay: ${Math.random() * 0.5}s;
            `}
          ></div>
        ))}
      </div>
    </div>

    <div class="text-[10px] font-mono tracking-[0.5em] uppercase text-white/40 mb-4">
      System Ready • Player 1 Authenticated
    </div>
    
    <p class="text-white/20 text-[10px] uppercase font-bold tracking-widest mb-10 text-center">
      © {currentYear} David Schuchert • BAD HERSFELD, DE • ALL RIGHTS RESERVED
    </p>

    <!-- ... rest of the component -->
    <nav class="flex flex-wrap justify-center gap-6 mb-10">
      <a href="#era-16bit" class="text-[10px] font-black uppercase text-white/40 tracking-widest hover:text-[#00ffff] transition-all">MAP</a>
      <a href="#era-gameboy" class="text-[10px] font-black uppercase text-white/40 tracking-widest hover:text-[#00ffff] transition-all">POKEDEX</a>
      <a href="#era-32bit" class="text-[10px] font-black uppercase text-white/40 tracking-widest hover:text-[#00ffff] transition-all">ROSTER</a>
      <a href="#era-hd" class="text-[10px] font-black uppercase text-white/40 tracking-widest hover:text-[#00ffff] transition-all">ACHIEVEMENTS</a>
      <a href="#era-nextgen" class="text-[10px] font-black uppercase text-white/40 tracking-widest hover:text-[#00ffff] transition-all">LOBBY</a>
    </nav>

    <div class="flex items-center gap-8 mb-12">
      <a href="https://github.com/DavidSchuchert" target="_blank" rel="noopener noreferrer" class="text-white/20 hover:text-white transition-all transform hover:scale-110" aria-label="GitHub">
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
      </a>
      <a href="https://www.linkedin.com/in/david-schuchert-0ab892283/" target="_blank" rel="noopener noreferrer" class="text-white/20 hover:text-white transition-all transform hover:scale-110" aria-label="LinkedIn">
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
      </a>
      <a href="https://dbe.academy" target="_blank" rel="noopener noreferrer" class="text-[10px] font-black text-white/20 hover:text-[#00ffff] transition-all tracking-widest px-3 py-1 border border-white/10 rounded-sm">DBE.ACADEMY</a>
    </div>

    <div class="flex flex-wrap justify-center gap-8 mb-4">
      <a href="/impressum" class="group flex items-center gap-2">
        <div class="w-6 h-6 rounded-sm border border-white/20 flex items-center justify-center text-[10px] font-black text-white/40 group-hover:border-white/60 group-hover:text-white transition-all">L</div>
        <span class="text-[10px] font-bold uppercase text-white/20 tracking-widest group-hover:text-white transition-all">LEGAL / IMPRESSUM</span>
      </a>
      <a href="/datenschutz" class="group flex items-center gap-2">
        <div class="w-6 h-6 rounded-sm border border-white/20 flex items-center justify-center text-[10px] font-black text-white/40 group-hover:border-white/60 group-hover:text-white transition-all">P</div>
        <span class="text-[10px] font-bold uppercase text-white/20 tracking-widest group-hover:text-white transition-all">PRIVACY / DATENSCHUTZ</span>
      </a>
    </div>

    <div class="mt-12 text-[8px] text-white/10 uppercase tracking-[1em] italic">
       Execution Engine: Astro x Vite
    </div>

  </div>
</footer>

<script>
  const scrollBtn = document.getElementById('scroll-to-top');
  const speedLines = document.getElementById('speed-lines');

  if (scrollBtn && speedLines) {
    scrollBtn.addEventListener('click', () => {
      // Show speed lines
      speedLines.style.opacity = '1';
      
      // Smooth scroll
      window.scrollTo({
        top: 0,
        behavior: 'smooth'
      });

      // Hide speed lines after a delay (enough for the scroll to finish)
      setTimeout(() => {
        speedLines.style.opacity = '0';
      }, 800);
    });
  }
</script>

<style>
  footer {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
  }

  .speed-line {
    border-radius: 9999px;
  }

  @keyframes drop {
    0% { transform: translateY(-100%); opacity: 0; }
    50% { opacity: 1; }
    100% { transform: translateY(500%); opacity: 0; }
  }
</style>
