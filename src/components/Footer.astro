---
const currentYear = new Date().getFullYear();

const socialLinks = [
  { name: 'GitHub', url: 'https://github.com/davidschuchert', icon: 'github' },
  { name: 'LinkedIn', url: 'https://linkedin.com/in/david-schuchert-0ab892283/', icon: 'linkedin' },
  { name: 'Xing', url: 'https://www.xing.com/profile/David_Schuchert', icon: 'xing' },
  { name: 'YouTube', url: 'https://www.youtube.com/@davidschuchert', icon: 'youtube' },
];

const navLinks = [
  { label: 'Über mich', href: '#about' },
  { label: 'Skills', href: '#skills' },
  { label: 'Projekte', href: '#projects' },
  { label: 'YouTube', href: '#youtube' },
  { label: 'Kontakt', href: '#contact' },
];
---

<footer class="py-12 px-4 bg-gray-100 dark:bg-gray-900/50 border-t border-gray-200 dark:border-gray-800">
  <div class="max-w-5xl mx-auto">
    <div class="flex flex-col md:flex-row items-center justify-between gap-8">
      <!-- Logo & tagline -->
      <div class="text-center md:text-left">
        <a href="#" class="inline-flex items-center gap-2 group">
          <span class="text-2xl group-hover:animate-bounce">🍻</span>
          <span class="font-bold text-xl gradient-text font-mono">&lt;DS&gt;</span>
        </a>
        <p class="text-gray-500 dark:text-gray-400 mt-2 text-sm">
          Built with ❤️ and too much Coffee ☕
        </p>
      </div>

      <!-- Nav links -->
      <nav class="flex flex-wrap justify-center gap-6" aria-label="Footer Navigation">
        {navLinks.map((link) => (
          <a href={link.href} class="text-gray-600 dark:text-gray-400 hover:text-amber-500 transition-colors text-sm font-medium">
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Social links -->
      <div class="flex gap-4">
        {socialLinks.map((social) => (
          <a
            href={social.url}
            target="_blank"
            rel="noopener noreferrer"
            class="p-2 rounded-lg bg-white dark:bg-gray-800 shadow hover:shadow-lg hover:-translate-y-1 transition-all text-gray-600 dark:text-gray-400 hover:text-amber-500 min-w-[44px] min-h-[44px] flex items-center justify-center"
            aria-label={`${social.name} Profil (öffnet in neuem Tab)`}
          >
            {social.icon === 'github' && (
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
              </svg>
            )}
            {social.icon === 'linkedin' && (
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            )}
            {social.icon === 'xing' && (
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M15.3 0H8.7C3.66 0 0 3.66 0 8.7v6.6C0 20.34 3.66 24 8.7 24h6.6c5.04 0 8.7-3.66 8.7-8.7V8.7C24 3.66 20.34 0 15.3 0zm3.06 17.5h-1.66V9.06h1.66v8.44zm-2.64-9.82c-.84 0-1.5-.66-1.5-1.5s.66-1.5 1.5-1.5 1.5.66 1.5 1.5-.66 1.5-1.5 1.5zm-4.14 9.82H6.86V9.06h4.92v8.44z"/>
              </svg>
            )}
            {social.icon === 'youtube' && (
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
              </svg>
            )}
          </a>
        ))}
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-800 flex flex-col md:flex-row items-center justify-between gap-4 text-sm text-gray-500 dark:text-gray-400">
      <p>
        <span class="font-mono text-amber-500">©</span> {currentYear} David Schuchert. Alle Rechte vorbehalten.
      </p>
      <p class="font-mono">
        Made with <span class="text-red-500">❤</span> in Bad Hersfeld 🍻
      </p>
    </div>
  </div>
</footer>
