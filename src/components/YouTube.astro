---
---

<section class="ps1-bios w-full min-h-[100vh] py-20 px-4 md:px-8 flex flex-col items-center justify-center overflow-hidden relative border-t-4 border-b-4 border-indigo-900">
  
  <!-- PS1 Floating Cubes (Background) -->
  <div class="absolute inset-0 z-0 pointer-events-none overflow-hidden">
    <div class="absolute top-1/4 left-1/4 w-32 h-32 bg-gradient-to-br from-[blue] via-[cyan] to-[yellow] opacity-20 floating-box box-1 blur-[1px]"></div>
    <div class="absolute top-1/2 right-1/4 w-24 h-24 bg-gradient-to-br from-[purple] via-[red] to-[yellow] opacity-15 floating-box box-2 blur-[1px]"></div>
    <div class="absolute bottom-1/4 left-1/3 w-40 h-40 bg-gradient-to-br from-[green] via-[yellow] to-[red] opacity-10 floating-box box-3 blur-[1px]"></div>
    <div class="absolute top-1/3 right-1/3 w-16 h-16 bg-gradient-to-br from-[blue] via-[cyan] to-[white] opacity-25 floating-box box-4 blur-[1px]"></div>
    <div class="absolute bottom-1/2 left-10 w-20 h-20 bg-gradient-to-br from-[purple] via-[blue] to-[green] opacity-10 floating-box box-5 blur-[1px]"></div>
    <div class="absolute top-10 right-10 w-28 h-28 bg-gradient-to-br from-[blue] via-[green] to-[yellow] opacity-10 floating-box box-6 blur-[1px]"></div>
    <div class="absolute bottom-10 right-20 w-36 h-36 bg-gradient-to-br from-[purple] via-[red] to-[yellow] opacity-05 floating-box box-7 blur-[1px]"></div>
    <div class="absolute top-1/2 left-1/4 w-12 h-12 bg-gradient-to-br from-[cyan] via-[white] to-[blue] opacity-30 floating-box box-8 blur-[1px]"></div>
    <div class="absolute bottom-1/3 right-1/4 w-22 h-22 bg-gradient-to-br from-[green] via-[red] to-[orange] opacity-15 floating-box box-9 blur-[1px]"></div>
    <div class="absolute top-3/4 right-1/2 w-30 h-30 bg-gradient-to-br from-[blue] via-[purple] to-[cyan] opacity-10 floating-box box-10 blur-[1px]"></div>
  </div>

  <div class="max-w-4xl w-full relative z-10 flex flex-col items-center">
    
    <!-- Sony BIOS Text Vibe -->
    <div class="text-center mb-16">
      <h2 class="text-2xl md:text-3xl text-white tracking-[0.3em] font-bold ps1-bios-font mb-2 drop-shadow-[0_2px_4px_#000]">
        HOCHDRUCK 3D
      </h2>
      <p class="text-xs text-[#a0a0ff] uppercase tracking-widest ps1-bios-font">
        Computer Entertainment
      </p>
    </div>

    <!-- The Two Classic Console Buttons: Memory Card & CD Player -->
    <div class="flex flex-col md:flex-row items-center justify-center gap-10 w-full mb-8">
      
      <!-- Memory Card (Decorative) -->
      <div class="ps1-button w-48 h-48 rounded-lg flex flex-col items-center justify-center shadow-[inset_0_0_20px_rgba(255,255,255,0.2),_0_10px_30px_rgba(0,0,0,0.8)] border border-t-[rgba(255,255,255,0.3)] border-b-[rgba(0,0,0,0.8)] cursor-default">
        <div class="w-16 h-20 bg-gray-300 border-b-4 border-gray-500 rounded-sm mb-4 flex items-start justify-center pt-2 shadow-[2px_2px_0_#000]">
           <div class="w-12 h-6 bg-black opacity-80"></div>
        </div>
        <span class="ps1-bios-font text-[#ffeb3b] text-sm tracking-widest drop-shadow-[1px_1px_0_#000]">MEMORY CARD</span>
      </div>

      <!-- CD Player (YouTube Link) -->
      <a href="https://youtube.com/c/hochdruck3d" target="_blank" class="ps1-button w-48 h-48 rounded-lg flex flex-col items-center justify-center shadow-[inset_0_0_20px_rgba(255,255,255,0.2),_0_10px_30px_rgba(0,0,0,0.8)] border border-t-[rgba(255,255,255,0.3)] border-b-[rgba(0,0,0,0.8)] hover:scale-110 transition-transform duration-300">
        <!-- CD Graphic -->
        <div class="w-20 h-20 rounded-full border-[8px] border-gray-200 bg-gradient-to-tr from-[#ff00ff] via-[#00ffff] to-[#ffff00] flex items-center justify-center mb-4 shadow-[2px_2px_0_#000]">
           <div class="w-4 h-4 rounded-full bg-black"></div>
        </div>
        <span class="ps1-bios-font text-[#00e5ff] text-sm tracking-widest drop-shadow-[1px_1px_0_#000] text-center px-2">CD PLAYER<br/><span class="text-[10px] text-white">YOUTUBE</span></span>
      </a>

    </div>

    <!-- Description Text (Emulating BIOS messages) -->
    <div class="mt-8 text-center bg-[#00000080] border border-[#a0a0ff] p-4 min-w-[300px]">
      <p class="ps1-bios-font text-[#ffffff] text-sm tracking-wider blink-text">
        Please insert 3D Printing media.
      </p>
    </div>

  </div>

</section>

<style>
  .ps1-bios-font {
    font-family: 'Arial', sans-serif;
    /* PS1 bios font is usually a very basic sans-serif like Arial/Helvetica, bold, with huge letter spacing */
    font-weight: bold;
  }

  .ps1-bios {
    background: radial-gradient(circle at center, #1b269b 0%, #000018 80%);
    box-shadow: inset 0 0 50px #000;
  }

  .ps1-button {
    background: linear-gradient(135deg, rgba(80,80,200,0.4) 0%, rgba(20,20,80,0.8) 100%);
    backdrop-filter: blur(4px);
  }

  .blink-text {
    animation: blink 2s infinite;
  }

  @keyframes blink {
    0%, 49% { opacity: 1; }
    50%, 100% { opacity: 0; }
  }

  /* Floating Box Animation Logic */
  .floating-box {
    border-radius: 4px;
    box-shadow: 0 0 30px rgba(0,255,255,0.2), inset 0 0 15px rgba(255,255,255,0.3);
    border: 1px solid rgba(255,255,255,0.1);
  }

  .box-1 { animation: float-rotate 25s linear infinite; }
  .box-2 { animation: float-rotate 35s linear infinite reverse; }
  .box-3 { animation: float-rotate 45s linear infinite; }
  .box-4 { animation: float-rotate 20s linear infinite reverse; }
  .box-5 { animation: float-rotate 30s linear infinite; }
  .box-6 { animation: float-rotate 28s linear infinite reverse; }
  .box-7 { animation: float-rotate 40s linear infinite; }
  .box-8 { animation: float-rotate 15s linear infinite; }
  .box-9 { animation: float-rotate 33s linear infinite reverse; }
  .box-10 { animation: float-rotate 50s linear infinite; }

  @keyframes float-rotate {
    0% { transform: translate(0, 0) rotate(0deg) scale(1); }
    33% { transform: translate(50px, -30px) rotate(120deg) scale(1.1); }
    66% { transform: translate(-30px, 40px) rotate(240deg) scale(0.9); }
    100% { transform: translate(0, 0) rotate(360deg) scale(1); }
  }
</style>