---

<section class="ps1-youtube w-full bg-black flex justify-center py-10 px-4 md:px-8">
  
  <div class="max-w-3xl w-full">
    
    <!-- Emulating a PS1 Sony Memory Card or save slot -->
    <div class="ps1-memory-card w-full bg-[#8c8c8c] p-1 shadow-[4px_4px_0_#000] border-t-2 border-l-2 border-[#d0d0d0] border-b-2 border-r-2 border-[#404040]">
      
      <div class="bg-[#2a2a2a] w-full p-6 pb-8 border-2 border-[#1a1a1a] flex flex-col md:flex-row items-center gap-6">
        
        <!-- Retro CD / Memory Icon Placeholder -->
        <div class="shrink-0 w-24 h-24 bg-gradient-to-br from-[#1a1a1a] to-[#0a0a0a] border-2 border-[#555] rounded-sm flex items-center justify-center p-2 shadow-inner">
          <svg class="w-12 h-12 text-[#ff0000] drop-shadow-[0_0_5px_rgba(255,0,0,0.8)]" fill="currentColor" viewBox="0 0 24 24">
            <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
        </div>

        <div class="flex-1 flex flex-col">
          <div class="flex items-end justify-between border-b-2 border-[#444] pb-2 mb-3">
            <h3 class="text-xl md:text-2xl text-white uppercase tracking-widest ps1-font">HOCHDRUCK 3D</h3>
            <span class="text-[#ffb74d] ps1-font text-sm">SLOT 1</span>
          </div>
          
          <p class="text-[#ccc] ps1-font text-sm leading-relaxed mb-6">
            Hardware, 3D-Druck und DIY Tech-Projekte. <br />
            Lade Spielstand...
          </p>
          
          <a href="https://youtube.com/c/hochdruck3d" target="_blank" class="self-start relative inline-block bg-[#404040] border-t-2 border-l-2 border-[#8c8c8c] border-b-2 border-r-2 border-[#202020] px-6 py-2 active:border-t-[#202020] active:border-l-[#202020] active:border-b-[#8c8c8c] active:border-r-[#8c8c8c] text-[#fff] uppercase ps1-font text-xs tracking-wider hover:text-[#ff0000] transition-colors">
            Kanal ansehen
          </a>
        </div>

      </div>

    </div>

  </div>
</section>

<style>
  .ps1-font {
    font-family: 'Times New Roman', Times, serif;
    letter-spacing: 0.05em;
  }
</style>