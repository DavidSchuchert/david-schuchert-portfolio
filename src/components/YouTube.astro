---

<section id="youtube" class="py-20 px-4 bg-gray-100 dark:bg-gray-900/50" aria-labelledby="youtube-heading">
  <div class="max-w-5xl mx-auto">
    <!-- Section header -->
    <div class="mb-12 text-center">
      <div class="ascii-box inline-block mb-4">
        <span class="text-amber-500">$</span> youtube-dl --list
      </div>
      <h2 id="youtube-heading" class="section-title">YouTube & Content</h2>
      <p class="text-gray-500 dark:text-gray-400 mt-2">Wissen teilen, Projekte dokumentieren</p>
    </div>

    <!-- YouTube Channel CTA -->
    <div class="text-center py-16 px-8 bg-white dark:bg-gray-900 rounded-2xl shadow-lg border border-gray-200 dark:border-gray-800">
      <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-red-500/10 flex items-center justify-center">
        <svg class="w-8 h-8 text-red-500" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
        </svg>
      </div>
      <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-2">3D-Druck & Tech auf YouTube</h3>
      <p class="text-gray-500 dark:text-gray-400 mb-6 max-w-md mx-auto">
        Von Arduino bis Webentwicklung — mein Kanal zeigt, wie Tech wirklich funktioniert.
      </p>
      <a href="https://www.youtube.com/c/hochdruck3d" 
         target="_blank" rel="noopener noreferrer"
         class="btn-primary inline-flex items-center gap-2"
         aria-label="David Schucherts YouTube-Kanal (öffnet in neuem Tab)">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.574z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        Kanal ansehen
      </a>
    </div>
  </div>
</section>