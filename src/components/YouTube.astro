---
const videos = [
  {
    title: 'TypeScript Grundlagen für Anfänger',
    description: 'Der perfekte Einstieg in TypeScript — von 0 auf 100 in 60 Minuten.',
    thumbnail: 'https://img.youtube.com/vi/dQw4w9WgXcQ/maxresdefault.jpg',
    url: 'https://www.youtube.com/@davidschuchert',
    views: '12K',
    duration: '58:24',
  },
  {
    title: 'React Hooks Deep Dive',
    description: 'useState, useEffect, useContext — alles was du über Hooks wissen musst.',
    thumbnail: 'https://img.youtube.com/vi/dQw4w9WgXcQ/maxresdefault.jpg',
    url: 'https://www.youtube.com/@davidschuchert',
    views: '8.5K',
    duration: '45:10',
  },
  {
    title: 'Docker für Web Developer',
    description: 'Container, Docker Compose, und Development-Workflows — praxisnah erklärt.',
    thumbnail: 'https://img.youtube.com/vi/dQw4w9WgXcQ/maxresdefault.jpg',
    url: 'https://www.youtube.com/@davidschuchert',
    views: '6.2K',
    duration: '1:02:33',
  },
];
---

<section id="youtube" class="py-20 px-4 bg-gray-100 dark:bg-gray-900/50">
  <div class="max-w-5xl mx-auto">
    <!-- Section header -->
    <div class="mb-12 text-center">
      <div class="ascii-box inline-block mb-4">
        <span class="text-amber-500">$</span> youtube-dl --list
      </div>
      <h2 class="section-title">YouTube & Talks</h2>
      <p class="text-gray-500 dark:text-gray-400 mt-2">Wissen teilen, Code erklären, Gaming-Outtakes 🍿</p>
    </div>

    <!-- Videos Grid -->
    <div class="grid md:grid-cols-3 gap-6">
      {videos.map((video, i) => (
        <a
          href={video.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group bg-white dark:bg-gray-900 rounded-xl shadow-lg hover:shadow-2xl transition-all duration-300 overflow-hidden"
          style={`animation-delay: ${i * 100}ms`}
        >
          <!-- Thumbnail -->
          <div class="relative aspect-video bg-gray-200 dark:bg-gray-800 overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-br from-amber-500/20 to-orange-500/20 group-hover:from-amber-500/40 group-hover:to-orange-500/40 transition-all"></div>
            <div class="absolute inset-0 flex items-center justify-center">
              <div class="w-16 h-16 rounded-full bg-white/90 flex items-center justify-center group-hover:scale-110 transition-transform shadow-lg">
                <svg class="w-8 h-8 text-red-600 ml-1" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                </svg>
              </div>
            </div>
            <!-- Duration badge -->
            <div class="absolute bottom-2 right-2 px-2 py-1 bg-black/80 text-white text-xs font-mono rounded">
              {video.duration}
            </div>
          </div>

          <!-- Content -->
          <div class="p-4">
            <h3 class="font-bold text-gray-900 dark:text-white mb-2 group-hover:text-amber-500 transition-colors line-clamp-2">
              {video.title}
            </h3>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-3 line-clamp-2">
              {video.description}
            </p>
            <div class="flex items-center justify-between text-xs text-gray-400">
              <span>👁 {video.views} Views</span>
              <span class="text-amber-500">YouTube →</span>
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- Channel CTA -->
    <div class="mt-12 text-center">
      <a href="https://www.youtube.com/@davidschuchert" target="_blank" rel="noopener noreferrer"
         class="btn-primary inline-flex items-center gap-2">
        <span>📺</span> Auf YouTube abonnieren
      </a>
    </div>
  </div>
</section>