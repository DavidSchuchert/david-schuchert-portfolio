<section class="next-gen-card w-full mb-8 relative overflow-hidden rounded-[2rem] bg-gradient-to-br from-[#111] to-[#050505] p-1 border border-white/10 shadow-2xl">
  
  <div class="absolute -right-20 -top-20 w-64 h-64 bg-red-600/30 blur-[100px] rounded-full pointer-events-none mix-blend-screen"></div>

  <div class="relative z-10 p-10 md:p-16 h-full flex flex-col md:flex-row items-center gap-10 bg-black/40 backdrop-blur-3xl rounded-[1.8rem]">
    
    <div class="md:flex-1">
      <h3 class="text-4xl md:text-5xl font-black text-white mb-4 tracking-tighter">
        Raytraced<br/>Reality.
      </h3>
      <p class="text-gray-400 text-lg md:text-xl font-light max-w-md text-balance mb-8">
        Auf meinem YouTube-Kanal <strong class="text-white font-medium">Hochdruck 3D</strong> erlebst du Next-Gen Tech-Reviews und Code-Deepdives in 4K.
      </p>
      <a href="https://youtube.com/c/hochdruck3d" target="_blank" class="inline-flex items-center justify-center px-8 py-4 rounded-full bg-white text-black font-semibold tracking-wide hover:scale-105 transition-transform duration-300">
        Kanal abonnieren
      </a>
    </div>

    <!-- Minimalist PS5-style icon / visual -->
    <div class="shrink-0 relative group perspective-1000">
      <div class="w-32 h-32 md:w-48 md:h-48 rounded-[2rem] bg-gradient-to-tr from-white/5 to-white/20 border border-white/20 backdrop-blur-xl flex items-center justify-center transform transition-transform duration-700 hover:rotate-y-12 hover:rotate-x-12 relative overflow-hidden shadow-[0_0_50px_rgba(255,255,255,0.1)]">
        <!-- Inner red glow -->
        <div class="absolute inset-x-0 bottom-0 h-1/2 bg-red-500/20 blur-2xl"></div>
        <svg class="w-16 h-16 md:w-24 md:h-24 text-white drop-shadow-[0_0_15px_rgba(255,0,0,0.5)] z-10" fill="currentColor" viewBox="0 0 24 24">
          <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
        </svg>
      </div>
    </div>

  </div>
</section>

<style>
  .perspective-1000 {
    perspective: 1000px;
  }
</style>