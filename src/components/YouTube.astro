---
const memorySlots = [
  { id: 'code', title: 'Coding', sub: 'Passion: Code / Lvl: Overflow', icon: '</>', color: 'bg-blue-500' },
  { id: 'print', title: '3D Printing', sub: 'Project: Physical / Status: Printing', icon: '3D', color: 'bg-green-500' },
  { id: 'mentor', title: 'Mentoring', sub: 'Class: Mentor / XP: Shared', icon: '?!', color: 'bg-yellow-400' },
  { id: 'pets', title: 'The Zoo', sub: 'Party: Dog & Chameleon / Buff: Joy', icon: '🐾', color: 'bg-orange-500' },
  { id: 'nerd', title: 'Nerd Mode', sub: 'Attribute: Nerd / Level: MAX', icon: '🤓', color: 'bg-purple-600' },
  { id: 'gamedev', title: 'GameDev', sub: 'Legacy: GameDev / World: Exported', icon: '🎮', color: 'bg-red-500' },
  { id: 'linux', title: 'Linux', sub: 'Host: Linux / Kernel: Love', icon: '🐧', color: 'bg-gray-800' },
];

const emptySlots = Array(15 - memorySlots.length).fill(null);
---

<section id="era-32bit-yt" class="ps1-bios w-full min-h-[100vh] py-20 px-4 md:px-8 flex flex-col items-center justify-center overflow-hidden relative border-t-4 border-b-4 border-indigo-900 group/bios">
  
  <!-- PS1 Floating Cubes (Background) - STAYING AS IS PER USER REQUEST -->
  <div class="absolute inset-0 z-0 pointer-events-none overflow-hidden opacity-30">
    <div class="absolute top-1/4 left-1/4 w-32 h-32 bg-gradient-to-br from-[blue] via-[cyan] to-[yellow] opacity-20 floating-box box-1 blur-[1px]"></div>
    <div class="absolute top-1/2 right-1/4 w-24 h-24 bg-gradient-to-br from-[purple] via-[red] to-[yellow] opacity-15 floating-box box-2 blur-[1px]"></div>
    <div class="absolute bottom-1/4 left-1/3 w-40 h-40 bg-gradient-to-br from-[green] via-[yellow] to-[red] opacity-10 floating-box box-3 blur-[1px]"></div>
    <div class="absolute top-1/3 right-1/3 w-16 h-16 bg-gradient-to-br from-[blue] via-[cyan] to-[white] opacity-25 floating-box box-4 blur-[1px]"></div>
    <div class="absolute bottom-1/2 left-10 w-20 h-20 bg-gradient-to-br from-[purple] via-[blue] to-[green] opacity-10 floating-box box-5 blur-[1px]"></div>
    <div class="absolute top-10 right-10 w-28 h-28 bg-gradient-to-br from-[blue] via-[green] to-[yellow] opacity-10 floating-box box-6 blur-[1px]"></div>
    <div class="absolute bottom-10 right-20 w-36 h-36 bg-gradient-to-br from-[purple] via-[red] to-[yellow] opacity-05 floating-box box-7 blur-[1px]"></div>
    <div class="absolute top-1/2 left-1/4 w-12 h-12 bg-gradient-to-br from-[cyan] via-[white] to-[blue] opacity-30 floating-box box-8 blur-[1px]"></div>
    <div class="absolute bottom-1/3 right-1/4 w-22 h-22 bg-gradient-to-br from-[green] via-[red] to-[orange] opacity-15 floating-box box-9 blur-[1px]"></div>
    <div class="absolute top-3/4 right-1/2 w-30 h-30 bg-gradient-to-br from-[blue] via-[purple] to-[cyan] opacity-10 floating-box box-10 blur-[1px]"></div>
  </div>

  <!-- HUD INTERFACE (Architectural Edges) -->
  <div class="absolute inset-0 pointer-events-none p-4 md:p-12 transition-opacity duration-500 group/hud z-20">
    <!-- Corners -->
    <div class="absolute top-8 left-8 w-12 h-12 border-t-2 border-l-2 border-white/20"></div>
    <div class="absolute top-8 right-8 w-12 h-12 border-t-2 border-r-2 border-white/20"></div>
    <div class="absolute bottom-8 left-8 w-12 h-12 border-b-2 border-l-2 border-white/20"></div>
    <div class="absolute bottom-8 right-8 w-12 h-12 border-b-2 border-r-2 border-white/20"></div>
    
    <!-- Technical Readouts -->
    <div class="absolute top-10 left-24 hidden md:flex flex-col gap-1">
      <span class="ps1-hud-font text-[8px] text-cyan-400/50 tracking-[0.3em]">SECTOR: 0xFD21</span>
      <span class="ps1-hud-font text-[8px] text-white/30 tracking-[0.3em]">BUFFER: OK_READY</span>
    </div>
    <div class="absolute bottom-10 right-24 hidden md:flex flex-col gap-1 items-end">
      <span class="ps1-hud-font text-[8px] text-magenta-400/50 tracking-[0.3em]">STREAM: 44.1KHZ</span>
      <span class="ps1-hud-font text-[8px] text-white/30 tracking-[0.3em]">DAVID COMPUTER ENTERTAINMENT</span>
    </div>
  </div>

  <!-- ARCHITECTURAL FOREGROUND -->
  <div id="ps1-main-menu" class="max-w-6xl w-full relative z-30 flex flex-col items-center transition-all duration-700">
    
    <!-- Sony BIOS Text Vibe -->
    <div class="text-center mb-24 transform hover:scale-105 transition-transform">
      <h2 class="text-3xl md:text-5xl text-white tracking-[0.5em] font-black ps1-bios-font mb-4 drop-shadow-[0_0_20px_rgba(255,255,255,0.4)]">
        HOCHDRUCK 3D
      </h2>
      <div class="w-full h-[2px] bg-gradient-to-r from-transparent via-white/40 to-transparent mb-4"></div>
      <p class="text-[10px] md:text-xs text-[#a0a0ff] uppercase tracking-[1em] ps1-bios-font opacity-60">
        System Architecture
      </p>
    </div>

    <!-- The Geometric Artifacts Dashboard -->
    <div class="flex flex-col md:flex-row items-center justify-center gap-24 md:gap-40 w-full relative">
      
      <!-- Connecting Data Line -->
      <div class="absolute top-1/2 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-white/10 to-transparent hidden md:block"></div>

      <!-- MEMORY CARD CLUSTER (Abstract Geometric) -->
      <div class="relative group/mem">
        <button id="btn-memcard" class="relative w-40 h-40 flex items-center justify-center transition-all duration-500 hover:scale-110 active:scale-95">
          <!-- Geometric Slabs -->
          <div class="absolute inset-0 bg-[#e0e0e0] opacity-40 shadow-xl border border-white/20 transform rotate-[15deg] translate-x-2 translate-y-2"></div>
          <div class="absolute inset-0 bg-[#cccccc] opacity-60 shadow-xl border border-white/20 transform rotate-[5deg] translate-x-4"></div>
          <div class="absolute inset-0 bg-white shadow-[0_0_30px_rgba(255,255,255,0.3)] border-2 border-white/50 transform -rotate-[5deg] flex flex-col items-center justify-center overflow-hidden">
             <!-- Internal LCD style icon -->
             <div class="w-20 h-12 bg-black/80 rounded-sm mb-2 flex items-center justify-center border border-white/10">
                <div class="w-16 h-2 bg-blue-500/50 rounded-full animate-pulse"></div>
             </div>
             <span class="ps1-hud-font text-[10px] text-gray-800 font-black tracking-widest">MEMORY CARD</span>
          </div>
        </button>
        <!-- Pulse Ring -->
        <div class="absolute -inset-4 border-2 border-white/5 rounded-full animate-ping opacity-20 pointer-events-none"></div>
      </div>

      <!-- CD PLAYERArtifact (The Ethereal Orb) -->
      <div class="relative group/cd">
        <a href="https://youtube.com/c/hochdruck3d" target="_blank" class="relative w-48 h-48 flex items-center justify-center transition-all duration-500 hover:scale-110 active:scale-95">
          <!-- The Glowing Orb -->
          <div class="absolute inset-2 rounded-full bg-gradient-to-tr from-[#ff00ff] via-[#00ffff] to-[#ffff00] animate-spin-slow opacity-40 blur-xl"></div>
          <div class="absolute inset-0 rounded-full bg-gradient-to-br from-white/80 via-white/20 to-black/20 shadow-[0_0_50px_rgba(255,255,255,0.4),inset_0_0_30px_rgba(0,0,0,0.5)] border-2 border-white/60 backdrop-blur-sm flex flex-col items-center justify-center overflow-hidden z-10">
             <div class="w-12 h-12 rounded-full border-4 border-white/30 flex items-center justify-center">
                <div class="w-2 h-2 rounded-full bg-white animate-ping"></div>
             </div>
             <span class="ps1-hud-font text-xs text-black font-black tracking-[0.2em] mt-4 drop-shadow-md">CD PLAYER</span>
             <span class="ps1-hud-font text-[8px] text-blue-800 font-bold tracking-[0.5em] opacity-60">YOUTUBE</span>
          </div>
          <!-- Orbiting Particles -->
          <div id="orb-particle-1" class="absolute w-4 h-4 bg-cyan-400 rounded-full blur-[2px] opacity-60"></div>
          <div id="orb-particle-2" class="absolute w-3 h-3 bg-magenta-400 rounded-full blur-[2px] opacity-40"></div>
        </a>
      </div>

    </div>

    <!-- Description Text (Technical Dashboard Messages) -->
    <div class="mt-24 text-center">
      <p class="ps1-hud-font text-white text-xs tracking-[0.4em] uppercase opacity-40 mb-4">Read-State Initialized</p>
      <div class="inline-block bg-white/5 border-t border-b border-white/20 py-4 px-12 backdrop-blur-md">
        <p class="ps1-bios-font text-[#ffffff] text-sm tracking-[0.2em] blink-text">
          PLEASE INSERT 3D-PRINTING MEDIA_
        </p>
      </div>
    </div>

  </div>

  <!-- MEMORY CARD MANAGER OVERLAY (STAYS AS IS BUT WITH REFINED STYLE) -->
  <div id="memcard-overlay" class="fixed inset-0 z-[100] bg-[#000] hidden flex-col items-center justify-center p-4">
    <div class="max-w-6xl w-full h-full bg-[#111] border-2 border-white/10 relative flex flex-col items-center p-8 bg-[radial-gradient(circle_at_center,#1a1a2a_0%,#000000_100%)] overflow-hidden">
      
      <!-- Overlay HUD Edges -->
      <div class="absolute inset-0 pointer-events-none opacity-20">
        <div class="absolute top-0 left-0 w-full h-[1px] bg-white/40"></div>
        <div class="absolute bottom-0 left-0 w-full h-[1px] bg-white/40"></div>
      </div>

      <div class="w-full flex items-center justify-between mb-8 border-b border-white/20 pb-4 relative z-10">
         <h3 class="ps1-hud-font text-white text-xl tracking-[0.4em] uppercase italic">Memory Card Manager</h3>
         <button id="btn-memcard-close" class="ps1-hud-font text-white hover:text-cyan-400 transition-colors text-sm tracking-widest">[X] EXIT_SYSTEM</button>
      </div>

      <!-- 15 Slots Grid (3x5) -->
      <div class="grid grid-cols-3 sm:grid-cols-5 gap-6 w-full flex-1 mb-8 overflow-y-auto pr-2 custom-scrollbar relative z-10">
        
        {memorySlots.map((slot) => (
          <div class="group relative aspect-square bg-white/5 border border-white/10 hover:border-cyan-400/50 hover:bg-white/10 transition-all p-4 flex flex-col items-center justify-center cursor-help">
            <div class={`w-14 h-14 md:w-20 md:h-20 ${slot.color} rounded-sm mb-4 shadow-[0_0_20px_rgba(0,0,0,0.5)] flex items-center justify-center overflow-hidden border border-white/20 group-hover:scale-110 transition-transform`}>
               <span class="text-white font-black text-2xl drop-shadow-md">{slot.icon}</span>
            </div>
            <span class="ps1-hud-font text-white text-[8px] md:text-[10px] uppercase tracking-widest opacity-60">{slot.title}</span>
            
            <!-- Tooltip -->
            <div class="absolute -bottom-2 left-1/2 -translate-x-1/2 translate-y-full w-56 bg-[#0a0a0a] border border-white/20 p-4 z-20 opacity-0 group-hover:opacity-100 transition-all pointer-events-none shadow-[0_10px_40px_rgba(0,0,0,0.8)] backdrop-blur-md">
               <p class="ps1-hud-font text-[9px] text-cyan-400 tracking-widest mb-2 border-b border-white/10 pb-1">SAVE_DATA_FOUND</p>
               <p class="ps1-hud-font text-[10px] text-white leading-relaxed uppercase opacity-80">{slot.sub}</p>
            </div>
          </div>
        ))}

        {emptySlots.map(() => (
          <div class="aspect-square bg-white/5 border border-white/5 opacity-10 flex items-center justify-center pattern-hatched">
            <span class="ps1-hud-font text-white text-[8px] uppercase tracking-widest italic">EMPTY_SEC</span>
          </div>
        ))}

      </div>

      <div class="w-full text-center border-t border-white/10 pt-4 relative z-10">
        <p class="ps1-hud-font text-white/30 text-[8px] tracking-[0.5em]">DAVID COMPUTER ENTERTAINMENT - KERNEL-v3.0.21</p>
      </div>
    </div>
  </div>

</section>

<style>
  .ps1-bios-font {
    font-family: 'Arial', sans-serif;
    font-weight: bold;
  }

  .ps1-hud-font {
    font-family: 'VT323', monospace;
    font-weight: bold;
  }

  .ps1-bios {
    background: radial-gradient(circle at center, #1b269b 0%, #000018 100%);
    box-shadow: inset 0 0 150px #000;
  }

  .ps1-button {
    background: linear-gradient(135deg, rgba(80,80,200,0.4) 0%, rgba(20,20,80,0.8) 100%);
    backdrop-filter: blur(4px);
  }

  .blink-text {
    animation: blink 2s infinite;
  }

  @keyframes blink {
    0%, 49% { opacity: 1; }
    50%, 100% { opacity: 0; }
  }

  /* Floating Box Animation Logic (User Requested: Stay exactly the same) */
  .floating-box {
    border-radius: 4px;
    box-shadow: 0 0 30px rgba(0,255,255,0.2), inset 0 0 15px rgba(255,255,255,0.3);
    border: 1px solid rgba(255,255,255,0.1);
  }

  .box-1 { animation: float-rotate 25s linear infinite; }
  .box-2 { animation: float-rotate 35s linear infinite reverse; }
  .box-3 { animation: float-rotate 45s linear infinite; }
  .box-4 { animation: float-rotate 20s linear infinite reverse; }
  .box-5 { animation: float-rotate 30s linear infinite; }
  .box-6 { animation: float-rotate 28s linear infinite reverse; }
  .box-7 { animation: float-rotate 40s linear infinite; }
  .box-8 { animation: float-rotate 15s linear infinite; }
  .box-9 { animation: float-rotate 33s linear infinite reverse; }
  .box-10 { animation: float-rotate 50s linear infinite; }

  @keyframes float-rotate {
    0% { transform: translate(0, 0) rotate(0deg) scale(1); }
    33% { transform: translate(50px, -30px) rotate(120deg) scale(1.1); }
    66% { transform: translate(-30px, 40px) rotate(240deg) scale(0.9); }
    100% { transform: translate(0, 0) rotate(360deg) scale(1); }
  }

  /* Custom Animations for New Artifacts */
  .animate-spin-slow {
    animation: spin 10s linear infinite;
  }
  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  #orb-particle-1 {
    animation: orbit 15s linear infinite;
  }
  #orb-particle-2 {
    animation: orbit 25s linear infinite reverse;
  }
  @keyframes orbit {
    0% { transform: rotate(0deg) translateX(100px) rotate(0deg); }
    100% { transform: rotate(360deg) translateX(100px) rotate(-360deg); }
  }

  .pattern-hatched {
    background-image: repeating-linear-gradient(45deg, transparent, transparent 5px, rgba(255,255,255,0.05) 5px, rgba(255,255,255,0.05) 10px);
  }

  .custom-scrollbar::-webkit-scrollbar {
    width: 4px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: rgba(0,0,0,1);
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: #333;
  }
</style>

<script>
  const btnMemcard = document.getElementById('btn-memcard');
  const btnMemcardClose = document.getElementById('btn-memcard-close');
  const overlay = document.getElementById('memcard-overlay');
  const mainMenu = document.getElementById('ps1-main-menu');

  if (btnMemcard && overlay && mainMenu) {
    btnMemcard.addEventListener('click', () => {
      overlay.classList.remove('hidden');
      overlay.classList.add('flex');
      mainMenu.classList.add('opacity-0', 'scale-95', 'blur-xl');
      document.body.style.overflow = 'hidden';
    });
  }

  if (btnMemcardClose && overlay && mainMenu) {
    btnMemcardClose.addEventListener('click', () => {
      overlay.classList.add('hidden');
      overlay.classList.remove('flex');
      mainMenu.classList.remove('opacity-0', 'scale-95', 'blur-xl');
      document.body.style.overflow = '';
    });
  }
</script>