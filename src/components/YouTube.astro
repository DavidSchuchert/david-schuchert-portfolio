---
const memorySlots = [
  { id: 'code', title: 'Coding', sub: 'Passion: Code / Lvl: Overflow', icon: '</>', color: 'bg-blue-500' },
  { id: 'print', title: '3D Printing', sub: 'Project: Physical / Status: Printing', icon: '3D', color: 'bg-green-500' },
  { id: 'mentor', title: 'Mentoring', sub: 'Class: Mentor / XP: Shared', icon: '?!', color: 'bg-yellow-400' },
  { id: 'pets', title: 'The Zoo', sub: 'Party: Dog & Chameleon / Buff: Joy', icon: '🐾', color: 'bg-orange-500' },
  { id: 'nerd', title: 'Nerd Mode', sub: 'Attribute: Nerd / Level: MAX', icon: '🤓', color: 'bg-purple-600' },
  { id: 'gamedev', title: 'GameDev', sub: 'Legacy: GameDev / World: Exported', icon: '🎮', color: 'bg-red-500' },
  { id: 'linux', title: 'Linux', sub: 'Host: Linux / Kernel: Love', icon: '🐧', color: 'bg-gray-800' },
];

const emptySlots = Array(15 - memorySlots.length).fill(null);
---

<section class="ps1-bios w-full min-h-[100vh] py-20 px-4 md:px-8 flex flex-col items-center justify-center overflow-hidden relative border-t-4 border-b-4 border-indigo-900 group/bios">
  
  <!-- PS1 Floating Cubes (Background) -->
  <div class="absolute inset-0 z-0 pointer-events-none overflow-hidden">
    <div class="absolute top-1/4 left-1/4 w-32 h-32 bg-gradient-to-br from-[blue] via-[cyan] to-[yellow] opacity-20 floating-box box-1 blur-[1px]"></div>
    <div class="absolute top-1/2 right-1/4 w-24 h-24 bg-gradient-to-br from-[purple] via-[red] to-[yellow] opacity-15 floating-box box-2 blur-[1px]"></div>
    <div class="absolute bottom-1/4 left-1/3 w-40 h-40 bg-gradient-to-br from-[green] via-[yellow] to-[red] opacity-10 floating-box box-3 blur-[1px]"></div>
    <div class="absolute top-1/3 right-1/3 w-16 h-16 bg-gradient-to-br from-[blue] via-[cyan] to-[white] opacity-25 floating-box box-4 blur-[1px]"></div>
    <div class="absolute bottom-1/2 left-10 w-20 h-20 bg-gradient-to-br from-[purple] via-[blue] to-[green] opacity-10 floating-box box-5 blur-[1px]"></div>
    <div class="absolute top-10 right-10 w-28 h-28 bg-gradient-to-br from-[blue] via-[green] to-[yellow] opacity-10 floating-box box-6 blur-[1px]"></div>
    <div class="absolute bottom-10 right-20 w-36 h-36 bg-gradient-to-br from-[purple] via-[red] to-[yellow] opacity-05 floating-box box-7 blur-[1px]"></div>
    <div class="absolute top-1/2 left-1/4 w-12 h-12 bg-gradient-to-br from-[cyan] via-[white] to-[blue] opacity-30 floating-box box-8 blur-[1px]"></div>
    <div class="absolute bottom-1/3 right-1/4 w-22 h-22 bg-gradient-to-br from-[green] via-[red] to-[orange] opacity-15 floating-box box-9 blur-[1px]"></div>
    <div class="absolute top-3/4 right-1/2 w-30 h-30 bg-gradient-to-br from-[blue] via-[purple] to-[cyan] opacity-10 floating-box box-10 blur-[1px]"></div>
  </div>

  <div id="ps1-main-menu" class="max-w-4xl w-full relative z-10 flex flex-col items-center transition-all duration-500">
    
    <!-- Sony BIOS Text Vibe -->
    <div class="text-center mb-16">
      <h2 class="text-2xl md:text-3xl text-white tracking-[0.3em] font-bold ps1-bios-font mb-2 drop-shadow-[0_2px_4px_#000]">
        HOCHDRUCK 3D
      </h2>
      <p class="text-xs text-[#a0a0ff] uppercase tracking-widest ps1-bios-font">
        Computer Entertainment
      </p>
    </div>

    <!-- The Two Classic Console Buttons: Memory Card & CD Player -->
    <div class="flex flex-col md:flex-row items-center justify-center gap-10 w-full mb-8">
      
      <!-- Memory Card (Button) -->
      <button id="btn-memcard" class="ps1-button w-48 h-48 rounded-lg flex flex-col items-center justify-center shadow-[inset_0_0_20px_rgba(255,255,255,0.2),_0_10px_30px_rgba(0,0,0,0.8)] border border-t-[rgba(255,255,255,0.3)] border-b-[rgba(0,0,0,0.8)] hover:scale-110 transition-transform duration-300 active:scale-95 group/btn">
        <div class="w-16 h-20 bg-gray-300 border-b-4 border-gray-500 rounded-sm mb-4 flex items-start justify-center pt-2 shadow-[2px_2px_0_#000] group-hover/btn:bg-white transition-colors">
           <div class="w-12 h-6 bg-black opacity-80"></div>
        </div>
        <span class="ps1-bios-font text-[#ffeb3b] text-sm tracking-widest drop-shadow-[1px_1px_0_#000]">MEMORY CARD</span>
      </button>

      <!-- CD Player (YouTube Link) -->
      <a href="https://youtube.com/c/hochdruck3d" target="_blank" class="ps1-button w-48 h-48 rounded-lg flex flex-col items-center justify-center shadow-[inset_0_0_20px_rgba(255,255,255,0.2),_0_10px_30px_rgba(0,0,0,0.8)] border border-t-[rgba(255,255,255,0.3)] border-b-[rgba(0,0,0,0.8)] hover:scale-110 transition-transform duration-300">
        <!-- CD Graphic -->
        <div class="w-20 h-20 rounded-full border-[8px] border-gray-200 bg-gradient-to-tr from-[#ff00ff] via-[#00ffff] to-[#ffff00] flex items-center justify-center mb-4 shadow-[2px_2px_0_#000]">
           <div class="w-4 h-4 rounded-full bg-black"></div>
        </div>
        <span class="ps1-bios-font text-[#00e5ff] text-sm tracking-widest drop-shadow-[1px_1px_0_#000] text-center px-2">CD PLAYER<br/><span class="text-[10px] text-white">YOUTUBE</span></span>
      </a>

    </div>

    <!-- Description Text (Emulating BIOS messages) -->
    <div class="mt-8 text-center bg-[#00000080] border border-[#a0a0ff] p-4 min-w-[300px]">
      <p class="ps1-bios-font text-[#ffffff] text-sm tracking-wider blink-text">
        Please insert 3D Printing media.
      </p>
    </div>

  </div>

  <!-- MEMORY CARD MANAGER OVERLAY -->
  <div id="memcard-overlay" class="fixed inset-0 z-[100] bg-[#222] hidden flex-col items-center justify-center p-4">
    <div class="max-w-6xl w-full h-full bg-[#3a3a3a] border-4 border-[#555] shadow-2xl relative flex flex-col items-center p-8 bg-[radial-gradient(circle_at_center,#4a4a4a_0%,#1a1a1a_100%)]">
      
      <div class="w-full flex items-center justify-between mb-8 border-b-2 border-white/20 pb-4">
         <h3 class="ps1-bios-font text-white text-xl md:text-3xl tracking-widest italic uppercase">Memory Card Manage</h3>
         <button id="btn-memcard-close" class="ps1-bios-font text-white hover:text-red-500 transition-colors text-xl">[X] BACK</button>
      </div>

      <!-- 15 Slots Grid (3x5) -->
      <div class="grid grid-cols-3 sm:grid-cols-5 gap-4 w-full flex-1 mb-8 overflow-y-auto pr-2 custom-scrollbar">
        
        {memorySlots.map((slot) => (
          <div class="group relative aspect-square bg-[#1a1a1a] border-2 border-white/10 hover:border-white transition-all p-2 flex flex-col items-center justify-center cursor-help">
            <div class={`w-12 h-12 md:w-16 md:h-16 ${slot.color} rounded-sm mb-2 shadow-[2px_2px_0_#000] flex items-center justify-center overflow-hidden border-2 border-white/20`}>
               <span class="text-white font-black text-xl md:text-2xl drop-shadow-md">{slot.icon}</span>
            </div>
            <span class="ps1-bios-font text-white text-[8px] md:text-[10px] uppercase tracking-tighter opacity-80">{slot.title}</span>
            
            <!-- Tooltip -->
            <div class="absolute -bottom-1 left-1/2 -translate-x-1/2 translate-y-full w-48 bg-black border border-white p-2 z-20 opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none shadow-xl">
               <p class="ps1-bios-font text-[10px] text-yellow-400 mb-1">Save Data Found:</p>
               <p class="ps1-bios-font text-[10px] text-white leading-tight">{slot.sub}</p>
            </div>
          </div>
        ))}

        {emptySlots.map(() => (
          <div class="aspect-square bg-[#1a1a1a] border-2 border-white/5 opacity-40 flex items-center justify-center pattern-hatched">
            <span class="ps1-bios-font text-white/10 text-[8px] uppercase tracking-widest italic">Empty Slot</span>
          </div>
        ))}

      </div>

      <div class="w-full text-center border-t border-white/10 pt-4">
        <p class="ps1-bios-font text-white/50 text-xs tracking-widest">SONY COMPUTER ENTERTAINMENT - DB-SYSTEM-v3.0</p>
      </div>
    </div>
  </div>

</section>

<style>
  .ps1-bios-font {
    font-family: 'Arial', sans-serif;
    font-weight: bold;
  }

  .ps1-bios {
    background: radial-gradient(circle at center, #1b269b 0%, #000018 80%);
    box-shadow: inset 0 0 100px #000;
  }

  .ps1-button {
    background: linear-gradient(135deg, rgba(80,80,200,0.4) 0%, rgba(20,20,80,0.8) 100%);
    backdrop-filter: blur(4px);
  }

  .blink-text {
    animation: blink 2s infinite;
  }

  @keyframes blink {
    0%, 49% { opacity: 1; }
    50%, 100% { opacity: 0; }
  }

  /* Floating Box Animation Logic */
  .floating-box {
    border-radius: 4px;
    box-shadow: 0 0 30px rgba(0,255,255,0.2), inset 0 0 15px rgba(255,255,255,0.3);
    border: 1px solid rgba(255,255,255,0.1);
  }

  .box-1 { animation: float-rotate 25s linear infinite; }
  .box-2 { animation: float-rotate 35s linear infinite reverse; }
  .box-3 { animation: float-rotate 45s linear infinite; }
  .box-4 { animation: float-rotate 20s linear infinite reverse; }
  .box-5 { animation: float-rotate 30s linear infinite; }
  .box-6 { animation: float-rotate 28s linear infinite reverse; }
  .box-7 { animation: float-rotate 40s linear infinite; }
  .box-8 { animation: float-rotate 15s linear infinite; }
  .box-9 { animation: float-rotate 33s linear infinite reverse; }
  .box-10 { animation: float-rotate 50s linear infinite; }

  @keyframes float-rotate {
    0% { transform: translate(0, 0) rotate(0deg) scale(1); }
    33% { transform: translate(50px, -30px) rotate(120deg) scale(1.1); }
    66% { transform: translate(-30px, 40px) rotate(240deg) scale(0.9); }
    100% { transform: translate(0, 0) rotate(360deg) scale(1); }
  }

  .pattern-hatched {
    background-image: repeating-linear-gradient(45deg, transparent, transparent 5px, rgba(255,255,255,0.05) 5px, rgba(255,255,255,0.05) 10px);
  }

  .custom-scrollbar::-webkit-scrollbar {
    width: 6px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: rgba(0,0,0,0.2);
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: #555;
    border-radius: 10px;
  }
</style>

<script>
  const btnMemcard = document.getElementById('btn-memcard');
  const btnMemcardClose = document.getElementById('btn-memcard-close');
  const overlay = document.getElementById('memcard-overlay');
  const mainMenu = document.getElementById('ps1-main-menu');

  if (btnMemcard && overlay && mainMenu) {
    btnMemcard.addEventListener('click', () => {
      overlay.classList.remove('hidden');
      overlay.classList.add('flex');
      mainMenu.classList.add('opacity-0', 'scale-95');
      document.body.style.overflow = 'hidden';
    });
  }

  if (btnMemcardClose && overlay && mainMenu) {
    btnMemcardClose.addEventListener('click', () => {
      overlay.classList.add('hidden');
      overlay.classList.remove('flex');
      mainMenu.classList.remove('opacity-0', 'scale-95');
      document.body.style.overflow = '';
    });
  }
</script>