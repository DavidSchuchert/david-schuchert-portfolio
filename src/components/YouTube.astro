---
---

<section class="ps1-bios w-full min-h-[100vh] py-20 px-4 md:px-8 flex flex-col items-center justify-center overflow-hidden relative border-t-4 border-b-4 border-indigo-900">
  
  <div class="absolute inset-0 pointer-events-none opacity-20 z-0">
    <div class="absolute top-1/4 left-1/4 w-32 h-32 border-4 border-[#00FFFF] transform rotate-45"></div>
    <div class="absolute top-1/2 right-1/4 w-24 h-24 border-4 border-[#FF00FF] transform rotate-12"></div>
    <div class="absolute bottom-1/4 left-1/3 w-40 h-40 border-4 border-[#FFFF00] transform -rotate-12"></div>
  </div>

  <!-- PS1 Audio Visualizer (Background) -->
  <div class="absolute inset-0 flex items-end justify-center gap-1 sm:gap-2 md:gap-4 opacity-30 z-0 pointer-events-none px-4">
    <div class="w-16 md:w-32 bg-gradient-to-t from-[blue] via-[cyan] to-[yellow] visualizer-bar bar-1"></div>
    <div class="w-16 md:w-32 bg-gradient-to-t from-[blue] via-[green] to-[yellow] visualizer-bar bar-2"></div>
    <div class="w-16 md:w-32 bg-gradient-to-t from-[purple] via-[red] to-[yellow] visualizer-bar bar-3"></div>
    <div class="w-16 md:w-32 bg-gradient-to-t from-[blue] via-[cyan] to-[white] visualizer-bar bar-4"></div>
    <div class="w-16 md:w-32 bg-gradient-to-t from-[purple] via-[blue] to-[green] visualizer-bar bar-5 hidden sm:block"></div>
    <div class="w-16 md:w-32 bg-gradient-to-t from-[green] via-[yellow] to-[red] visualizer-bar bar-6 hidden md:block"></div>
  </div>

  <div class="max-w-4xl w-full relative z-10 flex flex-col items-center">
    
    <!-- Sony BIOS Text Vibe -->
    <div class="text-center mb-16">
      <h2 class="text-2xl md:text-3xl text-white tracking-[0.3em] font-bold ps1-bios-font mb-2 drop-shadow-[0_2px_4px_#000]">
        HOCHDRUCK 3D
      </h2>
      <p class="text-xs text-[#a0a0ff] uppercase tracking-widest ps1-bios-font">
        Computer Entertainment
      </p>
    </div>

    <!-- The Two Classic Console Buttons: Memory Card & CD Player -->
    <div class="flex flex-col md:flex-row items-center justify-center gap-10 w-full mb-8">
      
      <!-- Memory Card (Decorative) -->
      <div class="ps1-button w-48 h-48 rounded-lg flex flex-col items-center justify-center shadow-[inset_0_0_20px_rgba(255,255,255,0.2),_0_10px_30px_rgba(0,0,0,0.8)] border border-t-[rgba(255,255,255,0.3)] border-b-[rgba(0,0,0,0.8)] cursor-default">
        <div class="w-16 h-20 bg-gray-300 border-b-4 border-gray-500 rounded-sm mb-4 flex items-start justify-center pt-2 shadow-[2px_2px_0_#000]">
           <div class="w-12 h-6 bg-black opacity-80"></div>
        </div>
        <span class="ps1-bios-font text-[#ffeb3b] text-sm tracking-widest drop-shadow-[1px_1px_0_#000]">MEMORY CARD</span>
      </div>

      <!-- CD Player (YouTube Link) -->
      <a href="https://youtube.com/c/hochdruck3d" target="_blank" class="ps1-button w-48 h-48 rounded-lg flex flex-col items-center justify-center shadow-[inset_0_0_20px_rgba(255,255,255,0.2),_0_10px_30px_rgba(0,0,0,0.8)] border border-t-[rgba(255,255,255,0.3)] border-b-[rgba(0,0,0,0.8)] hover:scale-110 transition-transform duration-300">
        <!-- CD Graphic -->
        <div class="w-20 h-20 rounded-full border-[8px] border-gray-200 bg-gradient-to-tr from-[#ff00ff] via-[#00ffff] to-[#ffff00] flex items-center justify-center mb-4 shadow-[2px_2px_0_#000]">
           <div class="w-4 h-4 rounded-full bg-black"></div>
        </div>
        <span class="ps1-bios-font text-[#00e5ff] text-sm tracking-widest drop-shadow-[1px_1px_0_#000] text-center px-2">CD PLAYER<br/><span class="text-[10px] text-white">YOUTUBE</span></span>
      </a>

    </div>

    <!-- Description Text (Emulating BIOS messages) -->
    <div class="mt-8 text-center bg-[#00000080] border border-[#a0a0ff] p-4 min-w-[300px]">
      <p class="ps1-bios-font text-[#ffffff] text-sm tracking-wider blink-text">
        Please insert 3D Printing media.
      </p>
    </div>

  </div>

</section>

<style>
  .ps1-bios-font {
    font-family: 'Arial', sans-serif;
    /* PS1 bios font is usually a very basic sans-serif like Arial/Helvetica, bold, with huge letter spacing */
    font-weight: bold;
  }

  .ps1-bios {
    background: radial-gradient(circle at center, #1b269b 0%, #000018 80%);
    box-shadow: inset 0 0 50px #000;
  }

  .ps1-button {
    background: linear-gradient(135deg, rgba(80,80,200,0.4) 0%, rgba(20,20,80,0.8) 100%);
    backdrop-filter: blur(4px);
  }

  .blink-text {
    animation: blink 2s infinite;
  }

  @keyframes blink {
    0%, 49% { opacity: 1; }
    50%, 100% { opacity: 0; }
  }

  /* Audio Visualizer Logic */
  .visualizer-bar {
    height: 10%;
    transform-origin: bottom;
    box-shadow: 0 0 20px rgba(0,255,255,0.5);
  }

  .bar-1 { animation: eq 1.2s ease-in-out infinite alternate; }
  .bar-2 { animation: eq 0.8s ease-in-out 0.2s infinite alternate; }
  .bar-3 { animation: eq 1.5s ease-in-out 0.5s infinite alternate; }
  .bar-4 { animation: eq 0.9s ease-in-out 0.1s infinite alternate; }
  .bar-5 { animation: eq 1.1s ease-in-out 0.4s infinite alternate; }
  .bar-6 { animation: eq 1.3s ease-in-out 0.3s infinite alternate; }

  @keyframes eq {
    0% { height: 10%; }
    50% { height: 60%; }
    100% { height: 30%; }
  }
</style>