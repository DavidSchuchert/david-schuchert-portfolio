<section id="youtube" class="py-20 px-4 bg-gray-100 dark:bg-gray-900/50" aria-labelledby="youtube-heading">
  <div class="max-w-5xl mx-auto">
    <!-- Section header -->
    <div class="mb-12 text-center">
      <div class="ascii-box inline-block mb-4">
        <span class="text-amber-500">$</span> youtube-dl --list
      </div>
      <h2 id="youtube-heading" class="section-title">YouTube & Talks</h2>
      <p class="text-gray-500 dark:text-gray-400 mt-2">Wissen teilen, Code erklären, Gaming-Outtakes 🍿</p>
    </div>

    <!-- YouTube Channel CTA -->
    <div class="text-center py-16 px-8 bg-white dark:bg-gray-900 rounded-2xl shadow-lg border border-gray-200 dark:border-gray-800">
      <div class="text-6xl mb-4">📺</div>
      <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-2">3D-Druck & More auf YouTube</h3>
      <p class="text-gray-500 dark:text-gray-400 mb-6 max-w-md mx-auto">
        Von Arduino bis Webentwicklung — David zeigt auf seinem Kanal, wie Tech wirklich funktioniert.
      </p>
      <a href="https://www.youtube.com/c/hochdruck3d" 
         target="_blank" rel="noopener noreferrer"
         class="btn-primary inline-flex items-center gap-2"
         aria-label="David Schucherts YouTube-Kanal (öffnet in neuem Tab)">
        <span aria-hidden="true">▶️</span> Kanal ansehen
      </a>
    </div>
  </div>
</section>
