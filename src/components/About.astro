          <div class="mt-4 flex justify-center gap-2">
            <span class="text-2xl hover:scale-110 transition-transform cursor-pointer">🍻</span>
            <span class="text-2xl hover:scale-110 transition-transform cursor-pointer">🎮</span>
            <span class="text-2xl hover:scale-110 transition-transform cursor-pointer">💻</span>
