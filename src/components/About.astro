          <div class="grid grid-cols-3 gap-4">
            <a href="https://github.com/davidschuchert" target="_blank" rel="noopener noreferrer" class="flex flex-col items-center p-3 bg-gray-50 dark:bg-gray-900 rounded-xl hover:bg-amber-50 dark:hover:bg-amber-900/20 transition-colors">
              <img src="https://img.shields.io/github/followers/DavidSchuchert?style=flat-square&label=Followers" alt="GitHub Followers" class="h-6 mb-1" />
              <span class="text-xs text-gray-500">Followers</span>
            </a>
            <a href="https://github.com/DavidSchuchert?tab=repositories" target="_blank" rel="noopener noreferrer" class="flex flex-col items-center p-3 bg-gray-50 dark:bg-gray-900 rounded-xl hover:bg-amber-50 dark:hover:bg-amber-900/20 transition-colors">
              <img src="https://img.shields.io/github/stars/DavidSchuchert?style=flat-square&label=Stars" alt="GitHub Stars" class="h-6 mb-1" />
              <span class="text-xs text-gray-500">Stars</span>
            </a>
            <a href="https://github.com/DavidSchuchert" target="_blank" rel="noopener noreferrer" class="flex flex-col items-center p-3 bg-gray-50 dark:bg-gray-900 rounded-xl hover:bg-amber-50 dark:hover:bg-amber-900/20 transition-colors">
              <img src="https://img.shields.io/github/languages/count/DavidSchuchert/DavidSchuchert?style=flat-square&label=Languages" alt="Languages" class="h-6 mb-1" />
              <span class="text-xs text-gray-500">Languages</span>
            </a>
          </div>
          <div class="mt-4">
            <img src="https://github-readme-stats.vercel.app/api/top-langs/?username=DavidSchuchert&layout=compact&theme=amber&hide_border=false" alt="Top Languages" class="rounded-lg" />
          </div>
        </div>

        <!-- Fun facts -->
