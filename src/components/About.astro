---
---

<section class="smw-map w-full min-h-[90vh] py-20 px-4 md:px-8 relative flex flex-col items-center justify-center overflow-hidden">
  
  <div class="absolute inset-0 bg-[#3CB043] z-0 smw-pattern" style="image-rendering: pixelated;"></div>

  <div class="max-w-5xl w-full relative z-10 flex flex-col items-center">
    
    <!-- SMW Wooden Level Sign -->
    <div class="text-center w-full mb-16 max-w-sm mx-auto relative z-20">
      <div class="pixel-wood-board px-6 py-4 relative shadow-[8px_8px_0_rgba(0,0,0,0.5)]">
         <h2 class="text-xl md:text-2xl text-white font-black snes-font uppercase drop-shadow-[2px_2px_0_#000]">
           WORLD 1: ABOUT
         </h2>
      </div>
    </div>

    <!-- The Map Container -->
    <div class="relative w-full h-[450px] flex items-center justify-center mt-10">
      
      <!-- Blocky / Pixelated SVG Path -->
      <!-- We use polyline for rigid, 90-degree retro paths instead of modern vector curves -->
      <svg class="absolute inset-x-0 mx-auto top-1/2 -translate-y-1/2 w-full max-w-[800px] h-[200px] pointer-events-none z-0" viewBox="0 0 800 200" preserveAspectRatio="none">
        
        <!-- Black shadow base for path -->
        <polyline points="50,100 250,100 250,180 550,180 550,60 750,60" fill="none" stroke="#000" stroke-width="16" stroke-linejoin="miter" />
        
        <!-- Yellowish/White SMW path -->
        <polyline points="50,100 250,100 250,180 550,180 550,60 750,60" fill="none" stroke="#fcd8a8" stroke-width="8" stroke-linejoin="miter" />
        
        <!-- Little track dots (CSS alternative is to use dash-array, SMW has little circles) -->
        <polyline points="50,100 250,100 250,180 550,180 550,60 750,60" fill="none" stroke="#fff" stroke-width="8" stroke-dasharray="10 20" stroke-linecap="square" />
      </svg>

      <!-- Absolute positioned Map Nodes to perfectly align with the polyline -->
      <div class="absolute w-full max-w-[800px] h-[200px] top-1/2 -translate-y-1/2 left-1/2 -translate-x-1/2">
        
        <!-- Node 1: Start (50, 100) -->
        <div class="absolute top-[100px] left-[50px] -translate-x-1/2 -translate-y-1/2 flex flex-col items-center group z-10 w-8 h-8">
          <!-- SMW Yellow Dot -->
          <div class="w-6 h-6 bg-[#ffff00] border-4 border-black shadow-[4px_4px_0_#000] cursor-pointer hover:scale-125 transition-transform" style="border-radius: 2px;"></div>
          <!-- Info Popup -->
          <div class="absolute bottom-12 w-48 bg-[#fff] border-[6px] border-black p-3 text-center opacity-0 group-hover:opacity-100 transition-opacity duration-300 z-20" style="border-radius: 4px; box-shadow: 4px 4px 0 #000;">
            <p class="snes-font text-black text-[10px] leading-relaxed font-bold">Start: Bad Hersfeld. Full-Stack Developer.</p>
          </div>
        </div>

        <!-- Node 2: Middle (250, 180) -->
        <div class="absolute top-[180px] left-[250px] -translate-x-1/2 -translate-y-1/2 flex flex-col items-center group z-10 w-8 h-8">
          <div class="w-6 h-6 bg-[#ffff00] border-4 border-black shadow-[4px_4px_0_#000] cursor-pointer hover:scale-125 transition-transform" style="border-radius: 2px;"></div>
          <!-- Info Popup -->
          <div class="absolute bottom-12 w-56 bg-[#fff] border-[6px] border-black p-3 text-center opacity-0 group-hover:opacity-100 transition-opacity duration-300 z-20" style="border-radius: 4px; box-shadow: 4px 4px 0 #000;">
            <p class="snes-font text-black text-[10px] leading-relaxed font-bold">Tech-Passionist. Ich meistere das gesamte Web-Stack-Spektrum.</p>
          </div>
        </div>

        <!-- Node 3: Castle / End (550, 60) -->
        <div class="absolute top-[60px] left-[550px] -translate-x-1/2 -translate-y-1/2 flex flex-col items-center group z-20 w-8 h-8">
          
          <div class="absolute -top-14 animate-bounce pointer-events-none">
             <img src="https://avatars.githubusercontent.com/u/142668300?v=4" alt="David" class="w-12 h-12 border-2 border-black object-cover shadow-[4px_4px_0_#000]" style="image-rendering: pixelated;" />
          </div>

          <div class="w-8 h-8 bg-[#e52521] border-4 border-black shadow-[4px_4px_0_#000] cursor-pointer hover:scale-125 transition-transform" style="border-radius: 2px;"></div>
          
          <div class="absolute bottom-12 -left-16 w-64 bg-[#fff] border-[6px] border-black p-3 text-left opacity-0 group-hover:opacity-100 transition-opacity duration-300 z-30" style="border-radius: 4px; box-shadow: 4px 4px 0 #000;">
            <p class="snes-font text-black text-[10px] leading-relaxed font-bold">
              <span class="text-red-600 block mb-2 text-sm">Dozent & Developer</span>
              DBE-Academy Guild.<br/> Party: 1x Hund, 1x Chamäleon.
            </p>
          </div>
        </div>

      </div>

    </div>

  </div>
</section>

<style>
  .snes-font {
    font-family: 'Press Start 2P', 'VT323', monospace;
  }

  /* Authentic SMW Pixel Pattern Background */
  .smw-pattern {
    /* Base green with a little noise/dirt pattern */
    background-image: 
      radial-gradient(#209020 15%, transparent 16%),
      radial-gradient(#209020 15%, transparent 16%);
    background-size: 32px 32px;
    background-position: 0 0, 16px 16px;
    opacity: 0.8;
  }

  /* Pixel Wood Board */
  .pixel-wood-board {
    background-color: #d18b47;
    /* Drawing borders using box-shadow to mimic pixel art borders */
    box-shadow: 
      inset 4px 4px 0px rgba(255,255,255,0.4),
      inset -4px -4px 0px rgba(0,0,0,0.4),
      6px 6px 0px rgba(0,0,0,0.8);
    border: 4px solid #5d3a1a;
  }

  .animate-bounce {
    animation: mario-jump 1s steps(2, end) infinite alternate;
  }

  @keyframes mario-jump {
    0% { transform: translateY(0); }
    100% { transform: translateY(-8px); }
  }
</style>