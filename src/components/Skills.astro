---
const inventory = [
  // User defined specific stats
  { name: 'TypeScript', ap: 'AP 9999', mp: '12 MP' },
  { name: 'React',      ap: 'AP 8500', mp: '15 MP' },
  { name: 'Node.js',    ap: 'AP 7200', mp: '10 MP' },
  { name: 'Laravel',    ap: 'AP 7800', mp: '18 MP' },
  { name: 'AI / LLMs',  ap: 'AP 6000', mp: '40 MP' },
  { name: 'Docker',     ap: 'AP 5500', mp: '8 MP' },
  
  // Extended Arsenal
  { name: 'HTML/SCSS',  ap: 'AP 9999', mp: '5 MP' },
  { name: 'MySQL',      ap: 'AP 8100', mp: '20 MP' },
  { name: 'Firebase',   ap: 'AP 7000', mp: '15 MP' },
];
---

<section class="ps1-inventory w-full min-h-[90vh] bg-[#000] py-20 px-4 md:px-8 flex flex-col items-center shadow-[inset_0_50px_100px_rgba(0,0,0,1)]">
  
  <div class="max-w-5xl w-full">
    
    <div class="flex items-end justify-between mb-4 px-2">
      <div class="flex items-end gap-6">
        <h2 class="text-3xl lg:text-4xl text-white tracking-widest font-bold ff7-text">Materia / Status</h2>
      </div>
      <span class="text-white ff7-text text-xl lg:text-2xl drop-shadow-[2px_2px_0_#000]">Lvl 99</span>
    </div>

    <!-- The classic FF7 style blue/gray menu box -->
    <div class="ff7-menu w-full border-[3px] rounded-sm p-8 md:p-12 bg-gradient-to-br from-[#00004a] via-[#00002a] to-[#00001a] min-h-[600px] flex flex-col">
      
      <!-- List Headers -->
      <div class="flex items-center justify-between border-b-4 border-gray-400 pb-4 mb-8">
        <span class="text-[#8aff80] drop-shadow-[2px_2px_0_#000] text-sm md:text-xl uppercase ff7-text w-1/3">Equipped</span>
        <span class="text-white text-sm md:text-xl uppercase ff7-text text-center w-1/3 opacity-50">Growth</span>
        <span class="text-white text-sm md:text-xl uppercase ff7-text text-right w-1/3 opacity-50">Cost</span>
      </div>

      <!-- Materia List Items -->
      <div class="flex flex-col gap-6 w-full">
        
        {inventory.map((item, index) => (
          <div class="group relative flex items-center justify-between cursor-default hover:bg-white/5 transition-colors rounded-sm pl-8 md:pl-16 pr-4 py-2 border-b border-white/10">
            
            <!-- Classic RPG Arrow Pointer -->
            <span class="absolute left-2 top-1/2 -translate-y-1/2 text-white opacity-0 group-hover:opacity-100 transition-opacity text-2xl ff7-text drop-shadow-[2px_2px_0_#000]">
              ▶
            </span>
            
            <!-- Name & Socket -->
            <div class="flex items-center gap-4 w-1/3">
              <!-- Materia Socket -->
              <div class="w-5 h-5 rounded-full border-2 border-gray-400 bg-black flex items-center justify-center inset-shadow">
                 <!-- Green Materia Orb -->
                 <div class="w-3 h-3 rounded-full bg-gradient-to-br from-[#8aff80] to-[#145a14] shadow-[0_0_8px_#8aff80]"></div>
              </div>
              <span class="text-white text-lg md:text-2xl ff7-text tracking-widest drop-shadow-[2px_2px_0_#000]">
                {item.name}
              </span>
            </div>
            
            <!-- AP -->
            <span class="text-white text-lg md:text-2xl ff7-text tracking-widest drop-shadow-[2px_2px_0_#000] text-center w-1/3 text-yellow-300">
              {item.ap}
            </span>

            <!-- MP -->
            <span class="text-white text-lg md:text-2xl ff7-text tracking-widest drop-shadow-[2px_2px_0_#000] text-right w-1/3 text-[#40c0ff]">
              {item.mp}
            </span>

          </div>
        ))}

      </div>

    </div>

  </div>

</section>

<style>
  /* Emulating classic early 3D era fonts */
  .ff7-text {
    font-family: 'Times New Roman', Times, serif;
    letter-spacing: 0.1em;
  }
  
  .inset-shadow {
    box-shadow: inset 2px 2px 4px rgba(255,255,255,0.2), inset -2px -2px 4px rgba(0,0,0,0.8);
  }

  .ps1-inventory {
    /* Slight CRT noise for 32-bit era */
    background-image: 
      linear-gradient(rgba(0,0,0,0.95), rgba(0,0,0,0.95)),
      url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
  }

  .ff7-menu {
    border-color: #cacaca;
    box-shadow: inset 0 0 10px rgba(0,0,0,1), 6px 6px 0px rgba(0,0,0,0.8);
    /* Metallic glossy border trick */
    border-image: linear-gradient(to bottom right, #fff, #555, #ccc, #333) 1;
  }
</style>
