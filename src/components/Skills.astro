---
const skillCategories = [
  {
    name: 'Frontend',
    skills: [
      { id: 'ts', name: 'TypeScript', level: 95, icon: 'TS' },
      { id: 'js', name: 'JavaScript', level: 98, icon: 'JS' },
      { id: 'react', name: 'React', level: 90, icon: 'RE' },
      { id: 'angular', name: 'Angular', level: 85, icon: 'NG' },
      { id: 'tw', name: 'Tailwind', level: 95, icon: 'TW' },
      { id: 'bs', name: 'Bootstrap', level: 90, icon: 'BS' },
      { id: 'html', name: 'HTML5', level: 99, icon: 'H5' },
      { id: 'css', name: 'CSS3', level: 95, icon: 'C3' },
    ]
  },
  {
    name: 'Backend',
    skills: [
      { id: 'node', name: 'Node.js', level: 92, icon: 'NO' },
      { id: 'php', name: 'PHP', level: 88, icon: 'PH' },
      { id: 'laravel', name: 'Laravel', level: 94, icon: 'LA' },
      { id: 'python', name: 'Python', level: 80, icon: 'PY' },
    ]
  },
  {
    name: 'Database',
    skills: [
      { id: 'mysql', name: 'MySQL', level: 90, icon: 'MY' },
      { id: 'firebase', name: 'Firebase', level: 92, icon: 'FB' },
      { id: 'redis', name: 'Redis', level: 75, icon: 'RD' },
    ]
  },
  {
    name: 'Ops & Tools',
    skills: [
      { id: 'docker', name: 'Docker', level: 88, icon: 'DO' },
      { id: 'git', name: 'Git', level: 95, icon: 'GT' },
      { id: 'linux', name: 'Linux', level: 85, icon: 'LX' },
    ]
  },
  {
    name: 'Tech & Maker',
    skills: [
      { id: 'print', name: '3D Printing', level: 99, icon: '3D' },
      { id: 'ada', name: 'Ausbilderschein (IHK)', level: 100, icon: 'TR' },
      { id: 'home', name: 'Smart Home', level: 94, icon: 'HM' },
      { id: 'ai', name: 'AI / LLMs', level: 90, icon: 'AI' },
      { id: 'electronics', name: 'Electronics', level: 85, icon: 'EL' },
    ]
  }
];

const allSkills = skillCategories.flatMap(cat => cat.skills.map(s => ({...s, category: cat.name})));
---

<section class="smash-skills w-full min-h-screen py-20 px-4 md:px-8 bg-[#111] relative flex flex-col items-center justify-center overflow-hidden">
  
  <!-- Background patterns -->
  <div class="absolute inset-0 opacity-10 pointer-events-none" style="background-image: radial-gradient(#fff 1px, transparent 1px); background-size: 40px 40px;"></div>
  
  <div class="max-w-6xl w-full relative z-10">
    <!-- Header: CHOOSE YOUR CHARACTER -->
    <div class="text-center mb-12">
      <h2 class="smash-font text-3xl md:text-5xl italic font-black text-white uppercase tracking-tighter drop-shadow-[4px_4px_0_#ff0055]">
        Choose Your Tech Stack
      </h2>
      <div class="h-2 w-full bg-gradient-to-r from-transparent via-[#ff0055] to-transparent mt-4 shadow-[0_0_20px_#ff0055]"></div>
    </div>

    <!-- The Character Roster Grid -->
    <div class="flex flex-wrap justify-center gap-2 md:gap-4 mb-16">
      {allSkills.map((skill) => (
        <div 
          class="skill-box group relative w-16 h-16 sm:w-20 sm:h-20 md:w-24 md:h-24 bg-[#333] border-4 border-[#555] hover:border-[#ff0055] hover:scale-110 transition-all duration-200 cursor-pointer overflow-hidden shadow-[4px_4px_0_rgba(0,0,0,0.5)]"
          data-skill-id={skill.id}
          data-skill-name={skill.name}
          data-skill-level={skill.level}
          data-skill-cat={skill.category}
        >
          <!-- Skill Icon Placeholder/Label -->
          <div class="absolute inset-0 flex flex-col items-center justify-center">
            <span class="smash-font text-white text-xl md:text-3xl font-black group-hover:text-[#ff0055] transition-colors">{skill.icon}</span>
            <span class="absolute bottom-1 text-[8px] md:text-[10px] text-gray-400 uppercase font-bold group-hover:text-white">{skill.name}</span>
          </div>
          
          <!-- Gloss layer -->
          <div class="absolute inset-0 bg-gradient-to-tr from-white/10 to-transparent pointer-events-none"></div>
        </div>
      ))}
    </div>

    <!-- The Player Selection Area (Detail View) -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      
      <!-- P1 Selection -->
      <div class="selection-pane p1 bg-gradient-to-br from-[#ff0055] to-[#80002b] rounded-xl border-4 border-white shadow-[0_15px_30px_rgba(255,0,85,0.4)] p-6 md:p-10 relative overflow-hidden h-64 flex flex-col justify-between">
        <div class="absolute top-2 left-4 smash-font text-4xl text-white/20 italic font-black">P1</div>
        
        <div id="p1-detail" class="relative z-10">
          <h3 id="p1-name" class="smash-font text-4xl md:text-6xl text-white italic font-black uppercase drop-shadow-lg mb-2">PICK A SKILL</h3>
          <p id="p1-cat" class="text-white/80 font-bold uppercase tracking-widest text-sm mb-4">Class: ---</p>
          
          <div class="w-full bg-black/40 h-8 rounded-sm overflow-hidden border-2 border-white/20 relative group">
            <div id="p1-level-bar" class="h-full bg-white transition-all duration-500" style="width: 0%"></div>
            <div class="absolute inset-0 flex items-center justify-center text-xs font-black text-white drop-shadow-md">
              MASTERY: <span id="p1-level-text">0%</span>
            </div>
          </div>
        </div>

        <div class="flex justify-end relative z-10">
          <div class="px-6 py-2 bg-white text-[#ff0055] font-black italic uppercase rounded-sm transform -rotate-3 text-2xl shadow-lg">READY!</div>
        </div>
        
        <!-- Background decorative icon -->
        <div class="absolute -bottom-10 -right-10 text-[10rem] text-white/10 italic font-black select-none">?</div>
      </div>

      <!-- CPU / Comparison (Random or dynamic) -->
      <div class="selection-pane cpu bg-gradient-to-br from-[#555] to-[#222] rounded-xl border-4 border-gray-400 shadow-[0_15px_30px_rgba(0,0,0,0.4)] p-6 md:p-10 relative overflow-hidden h-64 flex flex-col justify-between opacity-80">
        <div class="absolute top-2 left-4 smash-font text-4xl text-white/10 italic font-black">CPU</div>
        
        <div class="relative z-10">
          <h3 class="smash-font text-4xl md:text-6xl text-gray-400 italic font-black uppercase mb-2">FULL STACK</h3>
          <p class="text-gray-500 font-bold uppercase tracking-widest text-sm mb-4">Class: Generalist</p>
          
          <div class="w-full bg-black/40 h-8 rounded-sm overflow-hidden border-2 border-white/10 relative">
             <div class="h-full bg-gray-400" style="width: 99%"></div>
             <div class="absolute inset-0 flex items-center justify-center text-xs font-black text-white/50">
               SYNERGY: 99%
             </div>
          </div>
        </div>

        <div class="flex justify-end relative z-10">
          <div class="px-6 py-2 bg-gray-400 text-gray-800 font-black italic uppercase rounded-sm transform rotate-2 text-2xl">READY</div>
        </div>
      </div>

    </div>

  </div>
</section>

<style>
  .smash-font {
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    /* Smash fonts are often bold sans-serifs, usually italic */
    letter-spacing: -2px;
  }

  .skill-box {
    /* To mimic pixel borders and bevels */
    box-shadow: inset 2px 2px 0px rgba(255,255,255,0.1), inset -2px -2px 0px rgba(0,0,0,0.5);
  }

  .skill-box:hover {
    box-shadow: 0 0 20px #ff0055;
    z-index: 20;
  }
</style>

<script>
  document.querySelectorAll('.skill-box').forEach(box => {
    box.addEventListener('mouseenter', () => {
      const name = box.getAttribute('data-skill-name');
      const level = box.getAttribute('data-skill-level');
      const cat = box.getAttribute('data-skill-cat');
      
      const nameEl = document.getElementById('p1-name');
      const catEl = document.getElementById('p1-cat');
      const barEl = document.getElementById('p1-level-bar');
      const textEl = document.getElementById('p1-level-text');

      if (nameEl && catEl && barEl && textEl) {
        nameEl.textContent = name;
        catEl.textContent = `Class: ${cat}`;
        barEl.style.width = `${level}%`;
        textEl.textContent = `${level}%`;
      }
    });
  });
</script>
