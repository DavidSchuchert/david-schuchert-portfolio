---
import { Image } from 'astro:assets';
import vmtImg from '../assets/projects/vmt.png';
import joinImg from '../assets/projects/join.png';
import pokedexImg from '../assets/projects/pokedex.png';
import pollolocoImg from '../assets/projects/polloloco.png';
import batoceraImg from '../assets/projects/batocera.png';

const projects = [
  {
    "title": "VereinsManagement",
    "desc": "Specialized Laravel SaaS platform for managing complex club logic and administrative workflows. My most comprehensive architectural challenge.",
    "pts": "200G",
    "icon": '<svg class="w-8 h-8 text-[#8eb837]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>',
    "unlocked": "Unlocked 2024",
    "link": "https://vmt.david-schuchert.de/",
    "github": "https://github.com/DavidSchuchert/VereinsManagementTool-Laravel",
    "coverGradient": "from-green-700 to-emerald-500",
    "preview": vmtImg
  },
  {
    "title": "Batocera Dashboard PRO",
    "desc": "Next-gen web interface for Batocera Linux. Features real-time system analytics, library management, and remote terminal access.",
    "pts": "300G",
    "icon": '<svg class="w-8 h-8 text-[#8eb837]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01" /></svg>',
    "unlocked": "Unlocked 2026",
    "link": "https://bwdpro.david-schuchert.de/",
    "github": "https://github.com/DavidSchuchert/Batocera-WebDashboard-Pro/",
    "coverGradient": "from-indigo-600 to-purple-700",
    "preview": batoceraImg
  },
  {
    "title": "hermes-webui",
    "desc": "Agentic AI Interface for LLM workflows, offering a sophisticated control layer for autonomous models and agentic logic.",
    "pts": "150G",
    "icon": '<svg class="w-8 h-8 text-[#8eb837]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" /></svg>',
    "unlocked": "Unlocked 2025",
    "link": "#",
    "github": "https://github.com/DavidSchuchert/hermes-webui",
    "coverGradient": "from-blue-600 to-cyan-500",
    "preview": vmtImg,
    "isAi": true
  },
  {
    "title": "Join",
    "desc": "Kanban-inspired task manager with drag-and-drop mechanics, user assignment, and category filters. Built with modern JS.",
    "pts": "100G",
    "icon": '<svg class="w-8 h-8 text-[#8eb837]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>',
    "unlocked": "Unlocked 2022",
    "link": "/projects/join/index.html",
    "github": "https://github.com/DavidSchuchert/Join_David",
    "coverGradient": "from-indigo-600 to-blue-700",
    "preview": joinImg
  },
  {
    "title": "Pokédex",
    "desc": "REST API library indexing Pokémon data with PokéAPI integration for comprehensive search capability and retro UI.",
    "pts": "50G",
    "icon": '<svg class="w-8 h-8 text-[#8eb837]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4" /></svg>',
    "unlocked": "Unlocked 2021",
    "link": "/projects/PokeDex/index.html",
    "github": "https://github.com/DavidSchuchert/Pokedex",
    "coverGradient": "from-red-600 to-rose-700",
    "preview": pokedexImg
  },
  {
    "title": "El Pollo Loco",
    "desc": "Object-oriented Jump-and-Run adventure. Combat killer chickens while collecting salsa power-ups. A JS classic.",
    "pts": "25G",
    "icon": '<svg class="w-8 h-8 text-[#8eb837]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>',
    "unlocked": "Unlocked 2022",
    "link": "/projects/polloloco/index.html",
    "github": "https://github.com/DavidSchuchert/ElPoloLoco",
    "coverGradient": "from-yellow-400 to-orange-600",
    "preview": pollolocoImg
  }
];

const systemSpecs = [
  { label: 'OS Version', value: 'Astro v5.0.0 "Starlight"' },
  { label: 'System Kernel', value: 'Vite v6.0.0 / Node.js 20' },
  { label: 'UI Engine', value: 'TailwindCSS v3.4 "Hyper-Speed"' },
  { label: 'Production Mode', value: 'Dockerized SSR (Port 8486)' },
  { label: 'Developer', value: 'David Schuchert (Player 1)' },
  { label: 'Achievements', value: '100% Finalized UX' },
];
---

<section id="era-hd" class="xbox-blade w-full min-h-[90vh] py-32 px-4 md:px-8 bg-gradient-to-b from-[#e6e7eb] to-[#b3b6c2] text-[#333] overflow-hidden relative border-t-[12px] border-indigo-900 shadow-[0_-20px_40px_rgba(0,0,0,0.3)]">
  
  <!-- Subtle blade overlap to smooth transition -->
  <div class="absolute top-0 left-0 w-full h-8 bg-indigo-900/10 pointer-events-none"></div>
  
  <div class="max-w-7xl mx-auto flex flex-col h-full">
    
    <!-- Top Nav Blade Style -->
    <div class="flex items-center gap-2 mb-10 w-full overflow-hidden border-b-2 border-white shadow-sm pb-0">
      <button data-tab="games" class="tab-btn h-12 px-8 rounded-t-[20px] bg-gradient-to-b from-[#8eb837] to-[#71952a] flex items-center shadow-inner text-white font-bold text-lg transition-all hover:scale-105 active:scale-95 group relative z-10">
        Games
      </button>
      <button data-tab="system" class="tab-btn h-12 px-8 rounded-t-lg bg-gradient-to-b from-[#e5e5e5] to-[#cccccc] flex items-center text-gray-500 font-semibold hover:opacity-100 transition-all active:scale-95">
        System
      </button>
    </div>

    <!-- TAB CONTENT CONTAINER -->
    <div class="relative flex-1 min-h-[600px]">
      
      <!-- TAB 1: GAMES (Achievements) -->
      <div id="tab-games" class="tab-content grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10 md:gap-12 transition-all duration-500 translate-x-0 opacity-100">
        {projects.map(proj => (
          <div class="achievement-card flex flex-col bg-white rounded-xl shadow-[0_10px_20px_rgba(0,0,0,0.1)] border-4 border-[#fff] overflow-hidden hover:scale-[1.02] transition-transform duration-300 group">
            <!-- Mystery Header: Scanning Data Animation -->
            <div class={`w-full h-48 bg-gray-900 relative overflow-hidden flex items-center justify-center shadow-inner`}>
              <!-- Project Preview Image -->
              <div class="absolute inset-0 z-0">
                <Image 
                   src={proj.preview} 
                   alt={proj.title}
                   width={800}
                   height={450}
                   class={`w-full h-full object-cover object-top transition-transform duration-700 group-hover:scale-110 ${proj.isAi ? 'grayscale opacity-40 blur-[2px] contrast-150' : 'opacity-80'}`}
                />
              </div>

              <!-- Overlays -->
              <div class={`absolute inset-0 bg-gradient-to-br ${proj.coverGradient} mix-blend-multiply opacity-40 group-hover:opacity-20 transition-opacity`}></div>
              <div class="absolute inset-0 scan-lines opacity-20 pointer-events-none"></div>
              <div class="data-grid absolute inset-0 opacity-10 pointer-events-none"></div>
              
              <!-- Floating Icon in Glass Container -->
              <div class="w-16 h-16 bg-white/10 backdrop-blur-xl rounded-2xl flex items-center justify-center border-2 border-white/30 transform group-hover:scale-110 group-hover:-translate-y-2 transition-all duration-500 z-10 shadow-[0_8px_32px_rgba(0,0,0,0.3)]" set:html={proj.icon.replace('text-[#8eb837]', 'text-white drop-shadow-[0_0_15px_rgba(255,255,255,0.8)]')}></div>
              
              {proj.isAi && (
                <div class="absolute top-2 left-4 text-[#8eb837] text-[8px] font-black uppercase tracking-tighter bg-black/60 px-2 py-1 rounded backdrop-blur-md z-10 animate-pulse">
                  NEURAL_LINK_ACTIVE
                </div>
              )}

              <div class="absolute bottom-2 right-4 text-white/60 text-[9px] font-black uppercase tracking-[0.3em] font-mono z-10">
                [PROJECT_SCAN_{proj.pts}]
              </div>
            </div>

            <div class="p-6 relative z-10 flex flex-col flex-1 bg-gradient-to-b from-[#f8f9fa] to-[#e9ecef]">
              <div class="flex items-start justify-between mb-2">
                <h3 class="font-bold text-xl text-gray-800 leading-tight tracking-tight">{proj.title}</h3>
                <span class="text-[#8eb837] font-black text-lg shrink-0">{proj.pts}</span>
              </div>
              <p class="text-gray-600 text-sm flex-1 mb-6 focus-text-fix font-medium leading-relaxed">{proj.desc}</p>
              
              <div class="flex flex-col gap-4 mt-auto">
                <div class="flex-1 bg-gray-300/80 h-10 rounded-lg flex items-center px-4 justify-between border-2 border-white/50 shadow-inner group-hover:border-[#8eb837]/30 transition-colors">
                  <span class="text-gray-500 text-[10px] uppercase font-black tracking-tighter">{proj.unlocked}</span>
                  <div class="w-6 h-6 rounded-full bg-gradient-to-br from-[#8eb837] to-[#71952a] flex items-center justify-center text-white shadow-md text-[10px]">✓</div>
                </div>

                <div class="flex items-center justify-center gap-6">
                  <div class="flex flex-col items-center gap-1 group/btn">
                    <a href={proj.github} target="_blank" rel="noopener noreferrer" class="w-12 h-12 rounded-full bg-gradient-to-b from-blue-400 to-blue-700 border-[3px] border-white shadow-xl flex items-center justify-center text-white text-xl hover:scale-110 active:scale-90 transition-all font-black">X</a>
                    <span class="text-[8px] font-black text-gray-400 opacity-0 group-hover/btn:opacity-100 transition-opacity">SOURCE</span>
                  </div>
                  <div class="flex flex-col items-center gap-1 group/btn">
                    {proj.link === '#' ? (
                      <div class="w-12 h-12 rounded-full bg-gray-400 border-[3px] border-white shadow-md flex items-center justify-center text-gray-200 text-xl cursor-not-allowed font-black opacity-50">A</div>
                    ) : (
                      <a href={proj.link} target="_blank" rel="noopener noreferrer" class="w-12 h-12 rounded-full bg-gradient-to-b from-green-400 to-green-700 border-[3px] border-white shadow-xl flex items-center justify-center text-white text-xl hover:scale-110 active:scale-90 transition-all font-black">A</a>
                    )}
                    <span class="text-[8px] font-black text-gray-400 opacity-0 group-hover/btn:opacity-100 transition-opacity">{proj.link === '#' ? 'LOCKED' : 'LIVE'}</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>



      <!-- TAB 3: SYSTEM (Specs) -->
      <div id="tab-system" class="tab-content hidden absolute inset-0 transition-all duration-500 translate-x-20 opacity-0">
        <div class="max-w-3xl mx-auto bg-white/80 backdrop-blur-md rounded-2xl border-4 border-white shadow-2xl p-10">
          <div class="flex items-center gap-6 mb-10 pb-6 border-b-2 border-gray-200">
             <div class="w-20 h-20 bg-gradient-to-br from-green-500 to-green-700 rounded-full flex items-center justify-center text-white shadow-lg">
                <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
             </div>
             <div>
                <h3 class="text-3xl font-black italic text-gray-800 tracking-tighter">CONSOLE SYSTEM INFO</h3>
                <p class="text-green-600 font-bold uppercase text-xs tracking-widest">Network Status: Online (david-schuchert.de)</p>
             </div>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            {systemSpecs.map(spec => (
              <div class="flex flex-col border-l-4 border-green-500 pl-4">
                 <span class="text-[10px] uppercase font-black text-gray-400 tracking-widest">{spec.label}</span>
                 <span class="text-lg font-bold text-gray-800">{spec.value}</span>
              </div>
            ))}
          </div>

          <div class="mt-12 p-4 bg-gray-900 rounded-lg text-green-400 font-mono text-[10px] leading-tight">
             <p>> Initializing portfolio_v3_evolution_engine...</p>
             <p>> Loading retro_assets (8-bit, 16-bit, 32-bit, Next-Gen)...</p>
             <p>> Memory status: 512MB / 512MB (Batocera compatible)</p>
             <p>> All systems nominal. Welcome, Player 1.</p>
          </div>
        </div>
      </div>

    </div>

    <!-- Controller Help (Classic Dashboard Footer) -->
    <div class="mt-10 flex items-center justify-center gap-8 border-t-2 border-white/50 pt-6">
       <div class="flex items-center gap-2">
          <div class="w-6 h-6 rounded-full bg-blue-500 border border-white flex items-center justify-center text-white font-black text-xs">X</div>
          <span class="text-[10px] font-bold uppercase text-gray-600">Source</span>
       </div>
       <div class="flex items-center gap-2">
          <div class="w-6 h-6 rounded-full bg-green-500 border border-white flex items-center justify-center text-white font-black text-xs">A</div>
          <span class="text-[10px] font-bold uppercase text-gray-600">Enter</span>
       </div>
       <div class="flex items-center gap-2 opacity-50">
          <div class="w-6 h-6 rounded-full bg-red-500 border border-white flex items-center justify-center text-white font-black text-xs">B</div>
          <span class="text-[10px] font-bold uppercase text-gray-600">Back</span>
       </div>
       <div class="flex items-center gap-2 opacity-50">
          <div class="w-6 h-6 rounded-full bg-yellow-400 border border-white flex items-center justify-center text-black font-black text-xs">Y</div>
          <span class="text-[10px] font-bold uppercase text-gray-600">Search</span>
       </div>
    </div>

  </div>
</section>

<style>
  .xbox-blade {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
  }
  
  .tab-btn.active {
    background: linear-gradient(to bottom, #8eb837, #71952a) !important;
    color: white !important;
    opacity: 1 !important;
    transform: scale(1.05);
    z-index: 20;
    box-shadow: 0 5px 15px rgba(142, 184, 55, 0.4);
  }

  .tab-content {
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .tab-content.hidden {
    display: none;
    opacity: 0;
    transform: translateX(50px);
  }

  .tab-content:not(.hidden) {
    display: grid;
    animation: slideIn 0.5s ease-out forwards;
  }

  @keyframes slideIn {
    from { opacity: 0; transform: translateX(100px); }
    to { opacity: 1; transform: translateX(0); }
  }

  .pattern-hatched {
    background-image: repeating-linear-gradient(45deg, transparent, transparent 5px, rgba(0,0,0,0.02) 5px, rgba(0,0,0,0.02) 10px);
  }

  .scan-lines {
    background: linear-gradient(to bottom, transparent 50%, rgba(0,255,0,0.05) 50%);
    background-size: 100% 4px;
    animation: scan 10s linear infinite;
  }

  .data-grid {
    background-image: radial-gradient(circle, rgba(255,255,255,0.1) 1px, transparent 1px);
    background-size: 20px 20px;
    animation: pan 20s linear infinite;
  }

  @keyframes scan {
    from { background-position: 0 0; }
    to { background-position: 0 100%; }
  }

  @keyframes pan {
    from { background-position: 0 0; }
    to { background-position: 100% 100%; }
  }
</style>

<script>
  const tabBtns = document.querySelectorAll('.tab-btn');
  const tabContents = document.querySelectorAll('.tab-content');

  function switchTab(tabName) {
    // Update buttons
    tabBtns.forEach(btn => {
      const isActive = btn.getAttribute('data-tab') === tabName;
      btn.classList.toggle('active', isActive);
      
      // Update styling for inactive buttons
      if (!isActive) {
        btn.classList.add('bg-gradient-to-b', 'from-[#e5e5e5]', 'to-[#cccccc]', 'text-gray-500');
        btn.classList.remove('bg-gradient-to-b', 'from-[#8eb837]', 'to-[#71952a]', 'text-white');
      } else {
        btn.classList.remove('bg-gradient-to-b', 'from-[#e5e5e5]', 'to-[#cccccc]', 'text-gray-500');
        btn.classList.add('bg-gradient-to-b', 'from-[#8eb837]', 'to-[#71952a]', 'text-white', 'active');
      }
    });

    // Update content
    tabContents.forEach(content => {
      if (content.id === `tab-${tabName}`) {
        content.classList.remove('hidden');
      } else {
        content.classList.add('hidden');
      }
    });
  }

  tabBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const tab = btn.getAttribute('data-tab');
      switchTab(tab);
    });
  });

  // Init first tab
  switchTab('games');
</script>