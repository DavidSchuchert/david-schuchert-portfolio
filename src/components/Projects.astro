---
const projects = [
  {
    title: 'DBE-Academy Platform',
    description: 'Lernplattform für die DBE-Academy mit interaktiven Kursen, Code-Challenges und Live-Tracking.',
    tags: ['React', 'TypeScript', 'Node.js', 'PostgreSQL'],
    link: '#',
    github: '#',
    featured: true,
  },
  {
    title: 'TaskFlow Manager',
    description: 'Ein Productivity-Tool mit Kanban-Board, Zeit-Tracking und Team-Kollaboration. Perfekt für Developer.',
    tags: ['Next.js', 'Tailwind', 'Firebase', 'PWA'],
    link: '#',
    github: '#',
    featured: true,
  },
  {
    title: 'Portfolio Template',
    description: 'Open-Source Astro + Tailwind Portfolio Template mit Dark Mode und SEO-Optimierung.',
    tags: ['Astro', 'TypeScript', 'Tailwind'],
    link: '#',
    github: 'https://github.com/davidschuchert/portfolio-template',
    featured: false,
  },
];
---

<section id="projects" class="py-20 px-4">
  <div class="max-w-5xl mx-auto">
    <!-- Section header -->
    <div class="mb-12 text-center">
      <div class="ascii-box inline-block mb-4">
        <span class="text-amber-500">$</span> ls -la ./projects
      </div>
      <h2 class="section-title">Projekte</h2>
      <p class="text-gray-500 dark:text-gray-400 mt-2">Was ich so gebaut habe</p>
    </div>

    <!-- Projects Grid -->
    <div class="grid md:grid-cols-2 gap-8">
      {projects.map((project, i) => (
        <article
          class={`group relative bg-white dark:bg-gray-900 rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-300 overflow-hidden ${project.featured ? 'md:col-span-2' : ''}`}
          style={`animation-delay: ${i * 100}ms`}
        >
          <!-- Featured badge -->
          {project.featured && (
            <div class="absolute top-4 right-4 px-3 py-1 bg-gradient-to-r from-amber-500 to-orange-500 text-white text-xs font-bold rounded-full z-10">
              ⭐ Featured
            </div>
          )}

          <div class="p-8">
            <!-- Project header -->
            <div class="flex items-start justify-between mb-4">
              <h3 class="text-xl font-bold text-gray-900 dark:text-white group-hover:text-amber-500 transition-colors">
                {project.title}
              </h3>
              <span class="text-2xl">🎮</span>
            </div>

            <!-- Description -->
            <p class="text-gray-600 dark:text-gray-400 mb-6 leading-relaxed">
              {project.description}
            </p>

            <!-- Tags -->
            <div class="flex flex-wrap gap-2 mb-6">
              {project.tags.map((tag) => (
                <span class="px-3 py-1 bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 text-sm rounded-full font-mono">
                  {tag}
                </span>
              ))}
            </div>

            <!-- Links -->
            <div class="flex gap-4">
              {project.link !== '#' && (
                <a href={project.link} target="_blank" rel="noopener noreferrer"
                   class="btn-primary text-sm py-2">
                  <span class="flex items-center gap-2">
                    <span>🔗</span> Live Demo
                  </span>
                </a>
              )}
              {project.github !== '#' && (
                <a href={project.github} target="_blank" rel="noopener noreferrer"
                   class="btn-secondary text-sm py-2">
                  <span class="flex items-center gap-2">
                    <span>💻</span> Code
                  </span>
                </a>
              )}
            </div>
          </div>

          <!-- Hover glow effect -->
          <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none">
            <div class="absolute inset-0 bg-gradient-to-r from-amber-500/5 to-orange-500/5"></div>
          </div>
        </article>
      ))}
    </div>

    <!-- GitHub CTA -->
    <div class="mt-12 text-center">
      <a href="https://github.com/davidschuchert" target="_blank" rel="noopener noreferrer"
         class="inline-flex items-center gap-2 text-gray-500 hover:text-amber-500 transition-colors font-mono">
        <span class="text-amber-500">//</span> Mehr auf GitHub →
      </a>
    </div>
  </div>
</section>