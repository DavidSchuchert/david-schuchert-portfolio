---
const projects = [
  {
    title: 'DBE-Academy — Dozent',
    oneLiner: 'Ausbildung von Full-Stack Entwicklern.',
    whyMatters: 'Praxislernen statt Slides: meine Studenten coden von Tag eins und deployen echte Projekte. Mein Fokus: TypeScript, React, moderne Web-Architektur.',
    tags: ['TypeScript', 'React', 'Web Development', 'Education'],
    link: 'https://www.dbe.academy',
    github: '#',
    featured: true,
  },
  {
    title: 'VereinsManagementTool',
    oneLiner: 'Vereinsverwaltung mit Laravel — Mitglieder, Beiträge, Veranstaltungen.',
    whyMatters: 'Maßgeschneiderte Software für Vereine. Kein 08/15 — dieses Tool passt sich an, statt umgekehrt.',
    tags: ['Laravel 10', 'Blade', 'PHP 8.2', 'MySQL 8'],
    link: '#',
    github: 'https://github.com/DavidSchuchert/VereinsManagementTool-Laravel',
    featured: true,
  },
  {
    title: 'hermes-webui',
    oneLiner: 'Web-Interface für KI-Workflows und Agent-Steuerung.',
    whyMatters: 'KI ist nur so gut wie ihre Bedienbarkeit. Hermes macht Agentic AI zugänglich — ohne CLI-Fetisch.',
    tags: ['TypeScript', 'React', 'AI / LLMs'],
    link: '#',
    github: 'https://github.com/DavidSchuchert/hermes-webui',
    featured: false,
  },
];
---

<section id="projects" class="py-20 px-4" aria-labelledby="projects-heading">
  <div class="max-w-5xl mx-auto">
    <!-- Section header -->
    <div class="mb-12 text-center">
      <div class="ascii-box inline-block mb-4" aria-hidden="true">
        <span class="text-amber-500">$</span> ls -la ./projects
      </div>
      <h2 id="projects-heading" class="section-title">Projekte</h2>
      <p class="text-gray-500 dark:text-gray-400 mt-2">Ausgewählte Arbeiten</p>
    </div>

    <!-- Projects Grid -->
    <div class="grid md:grid-cols-2 gap-8">
      {projects.map((project, i) => (
        <article
          class={`group relative bg-white dark:bg-gray-900 rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-300 overflow-hidden border border-gray-200 dark:border-gray-800 hover:border-amber-500 ${project.featured ? 'md:col-span-2' : ''}`}
          style={`animation-delay: ${i * 100}ms`}
        >
          <div class="p-8">
            <!-- Project header -->
            <div class="flex items-start gap-4 mb-4">
              <div class="flex-1">
                <h3 class="text-xl font-bold text-gray-900 dark:text-white group-hover:text-amber-500 transition-colors">
                  {project.title}
                </h3>
                <p class="text-gray-500 dark:text-gray-400 text-sm mt-0.5">{project.oneLiner}</p>
              </div>
            </div>

            <!-- Why it matters -->
            <div class="mb-6 p-4 bg-amber-50 dark:bg-amber-900/10 border-l-4 border-amber-500 rounded-r-lg" role="note" aria-label="Projektbeschreibung">
              <p class="text-sm text-amber-800 dark:text-amber-300 font-medium">
                <span class="font-mono text-amber-500">// </span>{project.whyMatters}
              </p>
            </div>

            <!-- Tags -->
            <div class="flex flex-wrap gap-2 mb-6">
              {project.tags.map((tag) => (
                <span class="px-3 py-1 bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 text-xs rounded-full font-mono">
                  {tag}
                </span>
              ))}
            </div>

            <!-- Links -->
            <div class="flex gap-4">
              {project.link !== '#' && (
                <a href={project.link} target="_blank" rel="noopener noreferrer"
                   class="btn-primary text-sm py-2"
                   aria-label={`${project.title} auf der DBE-Academy ansehen (öffnet in neuem Tab)`}>
                  <span class="flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                    Mehr erfahren
                  </span>
                </a>
              )}
              {project.github !== '#' && (
                <a href={project.github} target="_blank" rel="noopener noreferrer"
                   class="btn-secondary text-sm py-2"
                   aria-label={`${project.title}: Quellcode auf GitHub ansehen (öffnet in neuem Tab)`}>
                  <span class="flex items-center gap-2">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
                    Code
                  </span>
                </a>
              )}
            </div>
          </div>

          <!-- Hover glow effect -->
          <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none">
            <div class="absolute inset-0 bg-gradient-to-r from-amber-500/5 to-orange-500/5"></div>
          </div>
        </article>
      ))}
    </div>

    <!-- GitHub CTA -->
    <div class="mt-12 text-center">
      <a href="https://github.com/DavidSchuchert" target="_blank" rel="noopener noreferrer"
         class="inline-flex items-center gap-2 text-gray-500 hover:text-amber-500 transition-colors font-mono"
         aria-label="Mehr Projekte auf GitHub ansehen (öffnet in neuem Tab)">
        <span class="text-amber-500" aria-hidden="true">//</span> Mehr auf GitHub
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </div>
</section>