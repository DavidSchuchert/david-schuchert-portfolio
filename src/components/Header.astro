---
const navLinks = [
  { label: 'MAP', href: '#era-16bit' },
  { label: 'POKEDEX', href: '#era-gameboy' },
  { label: 'ROSTER', href: '#era-32bit' },
  { label: 'ACHIEVEMENTS', href: '#era-hd' },
  { label: 'LOBBY', href: '#era-nextgen' },
];
---

<header class="w-full relative z-50 pt-8 pb-4 bg-black">
  <div class="max-w-7xl mx-auto px-4 md:px-8 border-b-4 border-white pb-4">
    <div class="flex flex-col md:flex-row items-center justify-between gap-4 md:gap-0">
      
      <a href="#" class="header-logo pixel-font text-[#00FFFF] text-base md:text-xl tracking-widest hover:text-white transition-colors retro-shadow">
        DAVID-SCHUCHERT.DE
      </a>

      <nav class="flex flex-wrap justify-center gap-4 md:gap-6">
        {navLinks.map((link) => (
          <a href={link.href} class="text-[10px] md:text-xs pixel-font tracking-widest uppercase text-gray-400 hover:text-white transition-colors hover:scale-110 transform">
            [{link.label}]
          </a>
        ))}
      </nav>

      <div class="flex items-center gap-4">
        <a href="https://github.com/DavidSchuchert" target="_blank" class="text-gray-400 hover:text-white transition-colors" title="GitHub">
          <svg class="w-5 h-5 md:w-6 md:h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        </a>
        <a href="mailto:kontakt@david-schuchert.de" class="text-gray-400 hover:text-white transition-colors" title="Email">
          <svg class="w-5 h-5 md:w-6 md:h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
        </a>
      </div>

    </div>
  </div>
</header>

<style>
  .pixel-font {
    font-family: 'Press Start 2P', monospace;
  }
  .retro-shadow {
    text-shadow: 2px 2px 0px #ff0055, -2px -2px 0px #00ffff;
  }
</style>
